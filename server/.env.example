PORT=8787
HOST=0.0.0.0

# Betfair credentials. Do not commit real values.
BETFAIR_APP_KEY=
BETFAIR_SESSION_TOKEN=

# Optional certificate login. Use only on the server, never in mini program code.
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_PATH=
BETFAIR_KEY_PATH=

# Sync interval in milliseconds. 300000 = 5 minutes.
BETFAIR_SYNC_INTERVAL_MS=300000

# Optional Betfair-only HTTP proxy pool. Other server APIs do not use it.
BETFAIR_PROXY_ENABLED=0
BETFAIR_PROXY_URLS=
# Leave empty to use the built-in public HTTP sources from Proxifly and ProxyScrape.
BETFAIR_PROXY_SOURCES=
BETFAIR_PROXY_ATTEMPTS=5
BETFAIR_PROXY_CACHE_MS=600000
BETFAIR_PROXY_MAX_CANDIDATES=200

# Betfair market history retention in days. Each sync records today's matches.
BETFAIR_HISTORY_RETENTION_DAYS=14

# Comma-separated CORS allowlist. Set to your mini program API domain if needed.
CORS_ALLOW_ORIGIN=*

# WeChat mini program login. Used by /api/auth/wechat-login.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Public HTTPS base URL for generated avatar URLs, for example https://www.ag-shield.com.
PUBLIC_BASE_URL=
