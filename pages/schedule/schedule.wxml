<view class="safe-page schedule-page" bindtouchstart="onPageTouchStart" bindtouchend="onPageTouchEnd">
  <view class="schedule-hero">
    <image class="schedule-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
    <view class="schedule-hero-copy">
      <text class="schedule-kicker">2026 FIFA WORLD CUP USA CANADA MEXICO</text>
      <text class="schedule-title">2026世界杯完整赛程</text>
    </view>
  </view>

  <scroll-view class="group-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="group-tab-row">
      <block wx:for="{{groupTabs}}" wx:key="key">
        <view class="group-tab {{item.active ? 'group-tab-active' : ''}}" data-group="{{item.key}}" bindtap="selectGroup">
          <text>{{item.key}}组</text>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="live-sync-bar" wx:if="{{isRefreshing}}">
    <text>{{liveSyncText}}</text>
  </view>

  <view class="standings-card glass">
    <view class="standings-head">
      <text>{{selectedGroup.name}}排名</text>
      <view class="standings-cols">
        <text>比赛</text>
        <text>胜/平/负</text>
        <text>进/失</text>
        <text>积分</text>
      </view>
    </view>
    <block wx:for="{{selectedGroup.table}}" wx:key="key">
      <view class="standing-row {{item.rankClass}}">
        <view class="standing-team">
          <text class="standing-rank">{{item.rank}}</text>
          <image class="standing-flag" src="{{item.team.flag}}" mode="aspectFit"></image>
          <text class="standing-abbr">{{item.abbr}}</text>
        </view>
        <view class="standing-stats">
          <text>{{item.played}}</text>
          <text>{{item.record}}</text>
          <text>{{item.goals}}</text>
          <text>{{item.points}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="remaining-section">
    <text class="section-title-text">剩余比赛</text>
    <block wx:if="{{groupMatches.length}}">
      <block wx:for="{{groupMatches}}" wx:key="id">
        <navigator wx:if="{{item.hasPrediction}}" class="fixture-row glass" url="/pages/detail/detail?id={{item.id}}&amp;source=upcoming" hover-class="fixture-hover">
          <view class="fixture-team">
            <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
            <text>{{item.home.abbr}}</text>
          </view>
          <view class="fixture-time">
            <text>{{item.dateText}}</text>
            <text>{{item.kickoff}}</text>
            <text wx:if="{{item.isLive}}" class="fixture-live-text">{{item.statusText}}</text>
          </view>
          <view class="fixture-team right">
            <text>{{item.away.abbr}}</text>
            <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
          </view>
          <text class="fixture-arrow">›</text>
        </navigator>
        <view wx:else class="fixture-row glass no-arrow">
          <view class="fixture-team">
            <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
            <text>{{item.home.abbr}}</text>
          </view>
          <view class="fixture-time">
            <text>{{item.dateText}}</text>
            <text>{{item.kickoff}}</text>
            <text wx:if="{{item.isLive}}" class="fixture-live-text">{{item.statusText}}</text>
          </view>
          <view class="fixture-team right">
            <text>{{item.away.abbr}}</text>
            <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
          </view>
        </view>
      </block>
    </block>
    <view class="empty-fixtures glass" wx:else>
      <text>本组暂无未开始比赛</text>
    </view>
  </view>

  <view class="bracket-section">
    <text class="section-title-text">淘汰赛图</text>
    <view class="bracket-board glass">
        <view class="bracket-rounds bracket-left-rounds">
          <block wx:for="{{bracket.leftRounds}}" wx:key="key">
            <view class="bracket-round bracket-round-{{item.matches.length}}">
              <block wx:for="{{item.matches}}" wx:for-item="match" wx:key="id">
                <view class="bracket-match-node">
                  <view class="bracket-team-row {{match.winnerSeed === match.home.seed ? 'winner-route' : ''}}">
                    <image wx:if="{{match.home.flag}}" src="{{match.home.flag}}" mode="aspectFit"></image>
                    <view wx:else class="seed-box"></view>
                    <text>{{match.home.abbr}}</text>
                  </view>
                  <view class="bracket-score-line" wx:if="{{match.score}}">
                    <text>{{match.score}}</text>
                    <text wx:if="{{match.extraScore}}" class="small-score">({{match.extraScore}})</text>
                    <text wx:if="{{match.penaltyScore}}" class="small-score">({{match.penaltyScore}})</text>
                  </view>
                  <view class="bracket-team-row {{match.winnerSeed === match.away.seed ? 'winner-route' : ''}}">
                    <image wx:if="{{match.away.flag}}" src="{{match.away.flag}}" mode="aspectFit"></image>
                    <view wx:else class="seed-box"></view>
                    <text>{{match.away.abbr}}</text>
                  </view>
                </view>
              </block>
            </view>
          </block>
        </view>

        <view class="bracket-center">
          <view class="medal-match final-match">
            <text class="medal-title">冠军对阵</text>
            <view class="bracket-match-node medal-node">
              <view class="bracket-team-row {{bracket.final.winnerSeed === bracket.final.home.seed ? 'winner-route' : ''}}">
                <image wx:if="{{bracket.final.home.flag}}" src="{{bracket.final.home.flag}}" mode="aspectFit"></image>
                <view wx:else class="seed-box"></view>
                <text>{{bracket.final.home.abbr}}</text>
              </view>
              <view class="bracket-score-line" wx:if="{{bracket.final.score}}">
                <text>{{bracket.final.score}}</text>
                <text wx:if="{{bracket.final.extraScore}}" class="small-score">({{bracket.final.extraScore}})</text>
                <text wx:if="{{bracket.final.penaltyScore}}" class="small-score">({{bracket.final.penaltyScore}})</text>
              </view>
              <view class="bracket-team-row {{bracket.final.winnerSeed === bracket.final.away.seed ? 'winner-route' : ''}}">
                <image wx:if="{{bracket.final.away.flag}}" src="{{bracket.final.away.flag}}" mode="aspectFit"></image>
                <view wx:else class="seed-box"></view>
                <text>{{bracket.final.away.abbr}}</text>
              </view>
            </view>
          </view>

          <image class="bracket-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>

          <view class="medal-match third-match">
            <text class="medal-title">3-4名对阵</text>
            <view class="bracket-match-node medal-node">
              <view class="bracket-team-row {{bracket.thirdPlace.winnerSeed === bracket.thirdPlace.home.seed ? 'winner-route' : ''}}">
                <image wx:if="{{bracket.thirdPlace.home.flag}}" src="{{bracket.thirdPlace.home.flag}}" mode="aspectFit"></image>
                <view wx:else class="seed-box"></view>
                <text>{{bracket.thirdPlace.home.abbr}}</text>
              </view>
              <view class="bracket-score-line" wx:if="{{bracket.thirdPlace.score}}">
                <text>{{bracket.thirdPlace.score}}</text>
                <text wx:if="{{bracket.thirdPlace.extraScore}}" class="small-score">({{bracket.thirdPlace.extraScore}})</text>
                <text wx:if="{{bracket.thirdPlace.penaltyScore}}" class="small-score">({{bracket.thirdPlace.penaltyScore}})</text>
              </view>
              <view class="bracket-team-row {{bracket.thirdPlace.winnerSeed === bracket.thirdPlace.away.seed ? 'winner-route' : ''}}">
                <image wx:if="{{bracket.thirdPlace.away.flag}}" src="{{bracket.thirdPlace.away.flag}}" mode="aspectFit"></image>
                <view wx:else class="seed-box"></view>
                <text>{{bracket.thirdPlace.away.abbr}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="bracket-rounds bracket-right-rounds">
          <block wx:for="{{bracket.rightRounds}}" wx:key="key">
            <view class="bracket-round bracket-round-{{item.matches.length}}">
              <block wx:for="{{item.matches}}" wx:for-item="match" wx:key="id">
                <view class="bracket-match-node">
                  <view class="bracket-team-row right {{match.winnerSeed === match.home.seed ? 'winner-route' : ''}}">
                    <text>{{match.home.abbr}}</text>
                    <image wx:if="{{match.home.flag}}" src="{{match.home.flag}}" mode="aspectFit"></image>
                    <view wx:else class="seed-box"></view>
                  </view>
                  <view class="bracket-score-line" wx:if="{{match.score}}">
                    <text>{{match.score}}</text>
                    <text wx:if="{{match.extraScore}}" class="small-score">({{match.extraScore}})</text>
                    <text wx:if="{{match.penaltyScore}}" class="small-score">({{match.penaltyScore}})</text>
                  </view>
                  <view class="bracket-team-row right {{match.winnerSeed === match.away.seed ? 'winner-route' : ''}}">
                    <text>{{match.away.abbr}}</text>
                    <image wx:if="{{match.away.flag}}" src="{{match.away.flag}}" mode="aspectFit"></image>
                    <view wx:else class="seed-box"></view>
                  </view>
                </view>
              </block>
            </view>
          </block>
        </view>
    </view>
  </view>
</view>
