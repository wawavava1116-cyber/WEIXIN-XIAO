  display: grid;
  grid-template-columns: 412rpx 124rpx 412rpx;
  align-items: center;
  gap: 12rpx;
  width: 960rpx;
  min-height: 620rpx;
  padding: 18rpx;
  border-color: rgba(214, 170, 76, 0.28);
