}

.bracket-rounds {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: stretch;
  gap: 8rpx;
  height: 584rpx;
}

.bracket-round {
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  min-width: 0;
}

.bracket-round-title {
  display: block;
  margin-bottom: 6rpx;
  color: rgba(214, 170, 76, 0.92);
  font-size: 15rpx;
  line-height: 1;
  font-weight: 1000;
  text-align: center;
}

.bracket-match-node {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 3rpx;
  min-width: 0;
  padding: 3rpx;
  border-radius: 7rpx;
}

.bracket-match-node::after {
  content: "";
  position: absolute;
  top: 50%;
  right: -8rpx;
  width: 8rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.22);
}

.bracket-right-rounds .bracket-match-node::after {
  left: -8rpx;
  right: auto;
}

.bracket-round-8 .bracket-match-node {
