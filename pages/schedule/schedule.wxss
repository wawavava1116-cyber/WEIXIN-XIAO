.schedule-page {
  padding-bottom: 28rpx;
  overflow-x: hidden;
}

.schedule-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 176rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
  border-radius: 22rpx;
  background: #000;
}

.schedule-logo {
  flex: none;
  width: 118rpx;
  height: 118rpx;
  border-radius: 18rpx;
  background: #000;
}

.schedule-hero-copy {
  min-width: 0;
}

.schedule-kicker,
.schedule-title {
  display: block;
}

.schedule-kicker {
  color: rgba(214, 170, 76, 0.94);
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 1000;
}

.schedule-title {
  margin-top: 8rpx;
  color: #fff;
  font-size: 40rpx;
  line-height: 1.12;
  font-weight: 1000;
}

.group-tabs {
  width: 100%;
  margin: 18rpx 0 14rpx;
  white-space: nowrap;
}

.group-tab-row {
  display: inline-flex;
  gap: 10rpx;
}

.group-tab {
  flex: none;
  min-width: 76rpx;
  padding: 12rpx 16rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.22);
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.72);
  background: #111;
  text-align: center;
  font-size: 22rpx;
  font-weight: 1000;
}

.group-tab-active {
  color: #050505;
  border-color: #d6aa4c;
  background: #d6aa4c;
}

.live-sync-bar {
  margin: -4rpx 2rpx 14rpx;
  color: rgba(214, 170, 76, 0.9);
  font-size: 20rpx;
  font-weight: 900;
}

.standings-card {
  padding: 14rpx;
  border-radius: 18rpx;
}

.standings-head,
.standing-row {
  display: grid;
  grid-template-columns: 1.18fr 1.72fr;
  align-items: center;
  gap: 8rpx;
}

.standings-head {
  padding: 4rpx 8rpx 12rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 19rpx;
  font-weight: 1000;
}

.standings-head > text {
  color: #d6aa4c;
  font-size: 24rpx;
}

.standings-cols,
.standing-stats {
  display: grid;
  grid-template-columns: 0.8fr 1.2fr 1fr 0.8fr;
  align-items: center;
  gap: 6rpx;
  text-align: center;
}

.standing-row {
  min-height: 58rpx;
  margin-top: 8rpx;
  padding: 8rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  font-weight: 1000;
}

.standing-team {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.standing-rank {
  width: 26rpx;
  text-align: center;
}

.standing-flag {
  width: 34rpx;
  height: 24rpx;
}

.standing-abbr {
  min-width: 0;
  font-size: 23rpx;
}

.rank-one {
  color: #050505;
  background: #36d36f;
}

.rank-two {
  color: #050505;
  background: #94e9a8;
}

.rank-three {
  color: #050505;
  background: #f4dc75;
}

.rank-four {
  color: #fff;
  background: rgba(255, 255, 255, 0.08);
}

.remaining-section,
.bracket-section {
  margin-top: 20rpx;
}

.section-title-text {
  display: block;
  margin: 0 4rpx 12rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 1000;
}

.fixture-row {
  display: grid;
  grid-template-columns: 1fr 1.08fr 1fr 26rpx;
  align-items: center;
  gap: 8rpx;
  min-height: 72rpx;
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  color: #fff;
}

.fixture-row.no-arrow {
  grid-template-columns: 1fr 1.08fr 1fr;
}

.fixture-hover {
  opacity: 0.92;
  transform: scale(0.99);
}

.fixture-team {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  font-size: 25rpx;
  font-weight: 1000;
}

.fixture-team.right {
  justify-content: flex-end;
}

.fixture-flag {
  width: 36rpx;
  height: 26rpx;
}

.fixture-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  line-height: 1.25;
  font-weight: 900;
  text-align: center;
}

.fixture-live-text {
  color: #39d97b;
}

.fixture-arrow {
  color: #d6aa4c;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 1000;
  text-align: right;
}

.empty-fixtures {
  padding: 20rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.bracket-board {
  position: relative;
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.bracket-half {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
}

.bracket-half.upper {
  padding-bottom: 28rpx;
}

.bracket-half.lower {
  padding-top: 28rpx;
}

.bracket-tie {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 30rpx 1fr;
  align-items: center;
  min-height: 88rpx;
}

.bracket-tie::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64%;
  height: 2rpx;
  transform: translate(-50%, -50%);
  background: rgba(255, 255, 255, 0.24);
}

.bracket-team {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  min-width: 0;
  color: #fff;
  font-size: 16rpx;
  line-height: 1;
  font-weight: 1000;
}

.bracket-team image,
.seed-box {
  width: 28rpx;
  height: 20rpx;
}

.winner-route {
  color: #39d97b;
}

.winner-route image,
.winner-route .seed-box {
  border-color: #39d97b;
  box-shadow: 0 0 0 2rpx rgba(57, 217, 123, 0.26);
}

.seed-box {
  border: 2rpx solid rgba(255, 255, 255, 0.38);
  border-radius: 4rpx;
}

.bracket-score {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #d6aa4c;
  font-size: 16rpx;
  line-height: 1.05;
  font-weight: 1000;
}

.small-score {
  margin-top: 2rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 13rpx;
}

.trophy-core {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  transform: translate(-50%, -50%);
  border: 2rpx solid rgba(214, 170, 76, 0.62);
  border-radius: 50%;
  color: #d6aa4c;
  background: #050505;
  font-size: 15rpx;
  line-height: 1;
  font-weight: 1000;
}

.trophy-icon {
  font-size: 34rpx;
  line-height: 1;
}
