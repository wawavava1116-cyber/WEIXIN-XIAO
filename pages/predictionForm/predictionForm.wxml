<view class="safe-page prediction-form-page">
  <view class="match-hero fixture-row glass" wx:if="{{match}}">
    <view class="fixture-team">
      <image class="fixture-flag" src="{{match.home.flag}}" mode="aspectFit"></image>
      <view>
        <text class="fixture-abbr">{{match.home.abbr}}</text>
        <text class="fixture-name">{{match.home.cn}}</text>
      </view>
    </view>
    <view class="fixture-time">
      <text>{{match.dateText}}</text>
      <text>{{match.kickoff}}</text>
      <text>VS</text>
    </view>
    <view class="fixture-team right">
      <view>
        <text class="fixture-abbr">{{match.away.abbr}}</text>
        <text class="fixture-name">{{match.away.cn}}</text>
      </view>
      <image class="fixture-flag" src="{{match.away.flag}}" mode="aspectFit"></image>
    </view>
  </view>

  <view class="pick-section">
    <text class="pick-title">胜平负</text>
    <view class="option-row">
      <block wx:for="{{resultOptions}}" wx:key="value">
        <view class="pick-chip {{item.selected ? 'selected' : ''}}" data-value="{{item.value}}" bindtap="selectResult">
          <text>{{item.value}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="pick-section">
    <text class="pick-title">备选胜平负</text>
    <text class="pick-note">可选</text>
    <view class="option-row">
      <block wx:for="{{backupOptions}}" wx:key="value">
        <view class="pick-chip {{item.selected ? 'selected' : ''}}" data-value="{{item.value}}" bindtap="selectBackup">
          <text>{{item.value}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="pick-section">
    <view class="section-head">
      <text class="pick-title">比分</text>
      <text class="pick-note">选择 2 个</text>
    </view>
    <block wx:for="{{scoreGroups}}" wx:key="key">
      <view class="score-group">
        <text class="score-group-title">{{item.title}}</text>
        <view class="score-grid">
          <block wx:for="{{item.options}}" wx:for-item="score" wx:key="value">
            <view class="score-card {{score.selected ? 'selected' : ''}}" data-value="{{score.value}}" bindtap="selectScore">
              <text>{{score.value}}</text>
            </view>
          </block>
        </view>
      </view>
    </block>
  </view>

  <view class="pick-section">
    <text class="pick-title">进球数</text>
    <view class="goal-grid">
      <block wx:for="{{goalOptions}}" wx:key="value">
        <view class="pick-chip goal-chip {{item.selected ? 'selected' : ''}}" data-value="{{item.value}}" bindtap="selectGoals">
          <text>{{item.value}}</text>
        </view>
      </block>
    </view>
  </view>

  <button class="submit-button" bindtap="submitPrediction">提交预测</button>
</view>
