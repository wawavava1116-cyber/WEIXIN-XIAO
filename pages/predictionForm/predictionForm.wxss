.prediction-form-page {
  padding: 14rpx 18rpx 20rpx;
  overflow-x: hidden;
}

.match-hero {
  display: grid;
  grid-template-columns: 1fr 1.08fr 1fr;
  align-items: center;
  gap: 8rpx;
  min-height: 76rpx;
  padding: 12rpx;
  border-radius: 14rpx;
}

.fixture-team {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.fixture-team.right {
  justify-content: flex-end;
  text-align: right;
}

.fixture-flag {
  flex: none;
  width: 44rpx;
  height: 32rpx;
}

.fixture-team > view {
  min-width: 0;
}

.fixture-abbr,
.fixture-name,
.fixture-time text {
  display: block;
}

.fixture-abbr {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 1000;
}

.fixture-name {
  margin-top: 5rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 16rpx;
  line-height: 1.15;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fixture-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  line-height: 1.15;
  font-weight: 900;
  text-align: center;
}

.fixture-time text:last-child {
  color: #d6aa4c;
  font-size: 22rpx;
  font-weight: 1000;
}

.pick-section {
  margin-top: 9rpx;
  width: 100%;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.pick-title,
.pick-note,
.score-group-title {
  display: inline-block;
}

.pick-title {
  margin: 0 2rpx 5rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 1000;
}

.pick-note {
  margin-left: 8rpx;
  color: rgba(214, 170, 76, 0.82);
  font-size: 16rpx;
  font-weight: 900;
}

.option-row,
.goal-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 10rpx;
  row-gap: 8rpx;
}

.goal-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.pick-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 54rpx;
  border: 1rpx solid rgba(214, 170, 76, 0.24);
  border-radius: 8rpx;
  color: #fff;
  background: #141414;
  font-size: 21rpx;
  font-weight: 1000;
  text-align: center;
}

.pick-chip text {
  display: block;
  width: 100%;
  text-align: center;
  line-height: 1.1;
}

.goal-chip {
  height: 50rpx;
  font-size: 20rpx;
}

.score-group {
  margin-top: 7rpx;
}

.score-group-title {
  margin: 0 2rpx 4rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 16rpx;
  font-weight: 900;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  column-gap: 8rpx;
  row-gap: 8rpx;
  width: 100%;
}

.score-card {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 50rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
  color: #fff;
  background: #151515;
  font-size: 20rpx;
  line-height: 1.1;
  font-weight: 1000;
  text-align: center;
}

.score-card text {
  display: block;
  width: 100%;
  text-align: center;
  line-height: 1.1;
}

.pick-chip.selected,
.score-card.selected {
  color: #050505;
  border-color: #d6aa4c;
  background: #d6aa4c;
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 52rpx;
  margin-top: 34rpx;
  border-radius: 8rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 22rpx;
  font-weight: 1000;
}
