.prediction-form-page {
  padding: 14rpx 18rpx 20rpx;
  overflow-x: hidden;
}

.match-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 82rpx minmax(0, 1fr);
  align-items: center;
  gap: 8rpx;
  min-height: 110rpx;
  padding: 12rpx;
  border-radius: 12rpx;
}

.match-team {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}

.match-team.right {
  align-items: flex-end;
}

.match-flag {
  width: 38rpx;
  height: 26rpx;
}

.match-abbr {
  margin-top: 4rpx;
  color: #fff;
  font-size: 25rpx;
  line-height: 1;
  font-weight: 1000;
}

.match-name {
  max-width: 100%;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 15rpx;
  line-height: 1.2;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.match-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 14rpx;
  line-height: 1.2;
  font-weight: 900;
  text-align: center;
}

.match-center text:last-child {
  color: #d6aa4c;
  font-size: 21rpx;
  font-weight: 1000;
}

.pick-section {
  margin-top: 9rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.pick-title,
.pick-note,
.score-group-title {
  display: inline-block;
}

.pick-title {
  margin: 0 2rpx 5rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 1000;
}

.pick-note {
  margin-left: 8rpx;
  color: rgba(214, 170, 76, 0.82);
  font-size: 16rpx;
  font-weight: 900;
}

.option-row,
.goal-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.goal-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.pick-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 54rpx;
  border: 1rpx solid rgba(214, 170, 76, 0.24);
  border-radius: 8rpx;
  color: #fff;
  background: #141414;
  font-size: 21rpx;
  font-weight: 1000;
}

.goal-chip {
  min-height: 48rpx;
  font-size: 20rpx;
}

.score-group {
  margin-top: 7rpx;
}

.score-group-title {
  margin: 0 2rpx 4rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 16rpx;
  font-weight: 900;
}

.score-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.score-card {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 50rpx;
  padding: 4rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
  color: #fff;
  background: #151515;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 1000;
}

.pick-chip.selected,
.score-card.selected {
  color: #050505;
  border-color: #d6aa4c;
  background: #d6aa4c;
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 52rpx;
  margin-top: 10rpx;
  border-radius: 8rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 22rpx;
  font-weight: 1000;
}
