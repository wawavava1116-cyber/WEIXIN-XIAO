<view class="safe-page history-page" bindtouchstart="onPageTouchStart" bindtouchend="onPageTouchEnd">
  <view class="hero">
    <view class="hero-mark">
      <image class="hero-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
    </view>
    <view class="hero-copy">
      <text class="hero-title">世界杯赛前播报</text>
      <text class="hero-subtitle">近 7 天赛程、赛前判断和比分倾向，一键看完整分析。</text>
      <text class="hero-version">{{databaseBadge}}</text>
      <text class="hero-model">预测模型：GPT5.5</text>
    </view>
  </view>

  <view class="search-bar glass">
    <view>
      <text class="search-title">按日期搜索</text>
      <text class="search-subtitle">展示最近 10 个历史预测</text>
    </view>
    <picker mode="selector" range="{{historyDates}}" value="{{historyDateIndex}}" bindchange="onHistoryDateChange">
      <view class="date-filter">{{selectedHistoryDate}}</view>
    </picker>
  </view>

  <view class="empty-history glass" wx:if="{{isLoadingHistory}}">
    <text>正在读取云端历史复盘...</text>
  </view>
  <view class="empty-history glass" wx:elif="{{historyLoadFailed}}">
    <text>云端历史读取失败，请下拉或稍后重试</text>
  </view>
  <block wx:elif="{{filteredHistoryMatches.length}}">
    <block wx:for="{{filteredHistoryMatches}}" wx:key="id">
      <navigator class="history-card glass" url="/pages/detail/detail?id={{item.id}}&amp;source=history" hover-class="history-card-hover">
        <view class="history-top">
          <view>
            <text class="history-date">{{item.dateText}} · {{item.kickoff}}</text>
            <text class="history-score">{{item.home.cn}} {{item.review.score}} {{item.away.cn}}</text>
          </view>
          <text class="review-percent percent-{{item.review.percentLevel}}">{{item.review.percent}}</text>
        </view>
        <view class="review-pick-grid">
          <view class="review-pick-cell review-pick-left">
            <text class="review-pick-label">胜负</text>
            <view class="review-pick-value">
              <text class="{{item.review.resultMainClass}}">{{item.review.resultMainShort || item.review.resultMain}}</text>
              <text wx:if="{{item.review.resultBackupShort}}" class="review-bracket">（</text>
              <text wx:if="{{item.review.resultBackupShort}}" class="{{item.review.resultBackupClass}}">{{item.review.resultBackupShort}}</text>
              <text wx:if="{{item.review.resultBackupShort}}" class="review-bracket">）</text>
            </view>
          </view>
          <view class="review-pick-cell review-pick-center">
            <text class="review-pick-label">比分</text>
            <view class="review-pick-value">
              <text class="{{item.review.scoreMainClass}}">{{item.review.scoreMain}}</text>
              <text wx:if="{{item.review.scoreBackup}}" class="review-bracket">（</text>
              <text wx:if="{{item.review.scoreBackup}}" class="{{item.review.scoreBackupClass}}">{{item.review.scoreBackup}}</text>
              <text wx:if="{{item.review.scoreBackup}}" class="review-bracket">）</text>
            </view>
          </view>
          <view class="review-pick-cell review-pick-right">
            <text class="review-pick-label">预期进球</text>
            <view class="review-pick-value">
              <text class="{{item.review.totalClass}}">{{item.review.totalPick || '未记录'}}</text>
            </view>
          </view>
        </view>
      </navigator>
    </block>
  </block>
  <view class="empty-history glass" wx:else>
    <text>该日期暂无历史预测</text>
  </view>
</view>
