.history-page {
  overflow: hidden;
}

.hero {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 226rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #000;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
}

.hero-mark {
  flex: none;
  width: 142rpx;
  height: 142rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #000;
}

.hero-logo {
  width: 100%;
  height: 100%;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.04;
  font-weight: 1000;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  line-height: 1.34;
}

.hero-version,
.hero-model {
  display: block;
  margin-top: 5rpx;
  color: rgba(214, 170, 76, 0.86);
  font-size: 18rpx;
  font-weight: 800;
}

.hero-model {
  color: rgba(255, 255, 255, 0.66);
}

.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 18rpx 0 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
}

.search-title {
  display: block;
  font-size: 28rpx;
  font-weight: 1000;
}

.search-subtitle {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 20rpx;
  font-weight: 800;
}

.date-filter {
  min-width: 142rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #050505;
  background: #d6aa4c;
  text-align: center;
  font-size: 21rpx;
  font-weight: 1000;
}

.history-card {
  display: block;
  margin-bottom: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  color: #fff;
  background: #101010;
}

.history-card-hover {
  transform: scale(0.99);
  opacity: 0.92;
}

.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.history-date {
  display: block;
  color: rgba(255, 255, 255, 0.62);
  font-size: 19rpx;
  font-weight: 850;
}

.history-score {
  display: block;
  margin-top: 4rpx;
  color: #fff;
  font-size: 29rpx;
  font-weight: 1000;
}

.review-percent {
  flex: none;
  min-width: 82rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 1000;
}

.percent-p100 {
  color: #29d66d;
  background: rgba(41, 214, 109, 0.12);
}

.percent-p75 {
  color: #facc15;
  background: rgba(250, 204, 21, 0.12);
}

.percent-p50 {
  color: #fb923c;
  background: rgba(251, 146, 60, 0.14);
}

.percent-p25,
.percent-p0 {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.12);
}

.history-body {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.78);
  font-size: 19rpx;
  font-weight: 850;
}

.muted-line {
  margin-top: 0;
  padding-top: 6rpx;
  border-top: 0;
  color: rgba(255, 255, 255, 0.56);
}

.history-body text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-history {
  padding: 20rpx;
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  font-weight: 850;
  text-align: center;
}
