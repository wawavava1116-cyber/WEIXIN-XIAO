<view class="safe-page home-page">
  <view class="startup-mask" wx:if="{{startupLoading}}">
    <view class="startup-panel">
      <text class="startup-percent">{{startupProgress}}%</text>
      <view class="startup-logo-shell">
        <image class="startup-logo startup-logo-base" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
        <view class="startup-logo-fill" style="height: {{startupProgress}}%;">
          <image class="startup-logo startup-logo-active" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>
  </view>

  <view class="warning-marquee">
    <text class="warning-track">⚠️ 理性观赛，远离违法赌博。本小程序内容仅供赛前信息参考，不提供任何投注服务。严禁利用预测内容参与任何形式的非法博彩。 ⚠️ 理性观赛，远离违法赌博。</text>
  </view>

  <view class="sync-bar" wx:if="{{isRefreshing}}">
    <view class="sync-spinner"></view>
    <text>{{syncText}}</text>
  </view>

  <view class="hero">
    <view class="hero-mark">
      <image class="hero-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
    </view>
    <view class="hero-copy">
      <text class="hero-title">世界杯赛前播报</text>
      <text class="hero-subtitle">近 7 天赛程、赛前判断和比分倾向，一键看完整分析。</text>
      <text class="hero-version">{{databaseBadge}}</text>
      <text class="hero-model">预测模型：GPT5.5</text>
    </view>
  </view>

  <view class="ticker glass">
    <text class="ticker-hot">今日焦点</text>
    <text class="ticker-text">{{featured.home.cn}} vs {{featured.away.cn}} · {{featured.pick.result}} · 比分预测 {{featured.pick.score}}</text>
  </view>

  <view class="review-panel glass">
    <view class="review-head history-header" bindtap="toggleReview">
      <view class="review-head-title history-title">
        <text class="review-title">历史复盘</text>
      </view>
      <view class="review-head-chart history-mini-chart">
        <view class="mini-chart-shell">
          <view class="mini-y-axis">
            <text>100%</text>
            <text>50%</text>
            <text>0</text>
          </view>
          <view class="chart-area compact-chart-area">
            <view class="chart-grid chart-grid-top"></view>
            <view class="chart-grid chart-grid-mid"></view>
            <view class="chart-grid chart-grid-bottom"></view>
            <block wx:for="{{reviewChart.segments}}" wx:key="index">
              <view class="chart-segment compact-chart-segment" style="left: {{item.left}}%; bottom: {{item.bottom}}%; width: {{item.width}}%; transform: rotate({{item.angle}}deg);"></view>
            </block>
            <block wx:for="{{reviewChart.points}}" wx:key="index">
              <view class="chart-point compact-chart-point" style="left: {{item.left}}%; bottom: {{item.bottom}}%;"></view>
            </block>
            <text class="mini-final-label">{{reviewChart.finalLabel}}</text>
          </view>
        </view>
      </view>
      <text class="review-arrow history-expand">{{reviewOpen ? '收起' : '展开'}}</text>
    </view>
    <view class="review-list" wx:if="{{reviewOpen}}">
      <block wx:for="{{finishedMatches}}" wx:key="id">
        <view class="review-item">
          <view class="review-match">
            <view class="review-topline">
              <text>{{item.home}} {{item.score}} {{item.away}}</text>
              <text class="review-percent percent-{{item.percentLevel}}">{{item.percent}}</text>
            </view>
            <view class="review-pick-grid">
              <view class="review-pick-cell review-pick-left">
                <text class="review-pick-label">胜负</text>
                <view class="review-pick-value">
                  <text class="{{item.resultMainClass}}">{{item.resultMainShort || item.resultMain}}</text>
                  <text wx:if="{{item.resultBackupShort}}" class="review-bracket">（</text>
                  <text wx:if="{{item.resultBackupShort}}" class="{{item.resultBackupClass}}">{{item.resultBackupShort}}</text>
                  <text wx:if="{{item.resultBackupShort}}" class="review-bracket">）</text>
                </view>
              </view>
              <view class="review-pick-cell review-pick-center">
                <text class="review-pick-label">比分</text>
                <view class="review-pick-value">
                  <text class="{{item.scoreMainClass}}">{{item.scoreMain}}</text>
                  <text wx:if="{{item.scoreBackup}}" class="review-bracket">（</text>
                  <text wx:if="{{item.scoreBackup}}" class="{{item.scoreBackupClass}}">{{item.scoreBackup}}</text>
                  <text wx:if="{{item.scoreBackup}}" class="review-bracket">）</text>
                </view>
              </view>
              <view class="review-pick-cell review-pick-right">
                <text class="review-pick-label">预期进球</text>
                <view class="review-pick-value">
                  <text class="{{item.totalClass}}">{{item.totalPick || '未记录'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section-title">
    <text>近 7 天比赛</text>
    <view class="section-actions">
      <text class="pill section-pill count-pill">{{matches.length}} 场</text>
      <navigator class="pill section-pill favorite-entry {{favoriteCount ? 'favorite-entry-solid' : 'favorite-entry-empty'}}" url="/pages/favorites/favorites" hover-class="favorite-entry-hover">关注</navigator>
      <navigator class="pill section-pill history-entry" url="/pages/history/history" hover-class="history-entry-hover">历史场次</navigator>
    </view>
  </view>

  <block wx:for="{{matches}}" wx:key="id">
    <navigator class="match-card glass" url="/pages/detail/detail?id={{item.id}}&amp;source=upcoming" hover-class="match-card-hover">
      <view class="match-top">
        <view class="match-meta-row">
          <view class="favorite-button {{item.isFavorite ? 'favorite-on' : ''}}" catchtap="toggleFavorite" data-id="{{item.id}}">
            <text>{{item.isFavorite ? '★' : '☆'}}</text>
          </view>
          <view class="match-meta-copy">
          <view class="date-line">
            <text>{{item.dateText}} · {{item.kickoff}} · {{item.weatherIcon}} {{item.weather}}</text>
            <text class="altitude-tag altitude-{{item.altitudeLevel}}">⛰️ {{item.altitude}}</text>
          </view>
          <text class="venue">{{item.group}} · {{item.venue}}</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="teams">
        <view class="team">
          <image class="flag-img" src="{{item.home.flag}}" mode="aspectFit"></image>
          <view class="team-name">
            <view class="team-title-line">
              <text class="cn">{{item.home.cn}}</text>
              <text class="en">{{item.home.en}}</text>
            </view>
            <text class="team-profile">FIFA {{item.home.rank}} · {{item.home.value}}</text>
          </view>
        </view>
        <view class="vs match-status status-{{item.matchStatus || 'not_started'}}">
          <text>{{item.matchStatus === 'live' ? (item.matchClock || item.phaseText || item.liveMinute || '进行中') : (item.statusText || 'VS')}}</text>
          <text class="live-score" wx:if="{{item.matchStatus !== 'not_started' && item.liveScore}}">{{item.liveScore}}</text>
          <text class="live-minute" wx:if="{{item.matchStatus !== 'not_started' && (item.phaseText || item.liveMinute)}}">{{item.phaseText || item.liveMinute}}</text>
        </view>
        <view class="team right">
          <view class="team-name">
            <view class="team-title-line">
              <text class="en">{{item.away.en}}</text>
              <text class="cn">{{item.away.cn}}</text>
            </view>
            <text class="team-profile">FIFA {{item.away.rank}} · {{item.away.value}}</text>
          </view>
          <image class="flag-img" src="{{item.away.flag}}" mode="aspectFit"></image>
        </view>
      </view>
      <view class="prediction-strip">
        <text>倾向：{{item.pick.result}}</text>
        <text>比分：{{item.pick.score}}</text>
        <text>进球：{{item.pick.total}}</text>
      </view>
    </navigator>
  </block>
</view>
