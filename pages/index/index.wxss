.home-page {
  overflow: hidden;
}

.startup-mask {
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: #050505;
}

.startup-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  max-width: 520rpx;
  transform: translateY(-8vh);
}

.startup-logo-shell {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  overflow: hidden;
  border-radius: 26rpx;
  background: #000;
  box-shadow: 0 20rpx 44rpx rgba(0, 0, 0, 0.36);
}

.startup-logo {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 168rpx;
  height: 168rpx;
  margin: 6rpx;
  border-radius: 22rpx;
  background: #000;
}

.startup-logo-base {
  opacity: 0.18;
  filter: grayscale(1);
}

.startup-logo-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  transition: height 0.18s ease;
}

.startup-logo-active {
  opacity: 1;
}

.startup-percent {
  min-width: 48rpx;
  color: #fff;
  font-size: 17rpx;
  line-height: 1;
  font-weight: 1000;
  text-align: center;
}

.announcement-mask {
  position: fixed;
  z-index: 980;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 42rpx;
  background: transparent;
  box-sizing: border-box;
  pointer-events: none;
}

.announcement-card {
  position: relative;
  width: 86%;
  max-width: 560rpx;
  padding: 38rpx 26rpx 24rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.76);
  border-radius: 18rpx;
  background: #fff8e8;
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.42);
  box-sizing: border-box;
  pointer-events: auto;
}

.announcement-title {
  display: block;
  color: #8f1318;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 1000;
  text-align: center;
}

.announcement-body {
  display: block;
  margin-top: 18rpx;
  color: #1a1a1a;
  font-size: 24rpx;
  line-height: 1.52;
  font-weight: 800;
}

.announcement-update {
  margin-top: 18rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(143, 19, 24, 0.18);
  border-radius: 12rpx;
  background: rgba(143, 19, 24, 0.06);
}

.announcement-update-title,
.announcement-update-text {
  display: block;
}

.announcement-update-title {
  color: #8f1318;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 1000;
}

.announcement-update-text {
  margin-top: 6rpx;
  color: #2b2b2b;
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 800;
}

.announcement-close {
  position: absolute;
  top: 18rpx;
  right: 22rpx;
  z-index: 2;
  width: 44rpx;
  height: 44rpx;
  color: #e80f16;
  font-size: 42rpx;
  line-height: 44rpx;
  font-weight: 1000;
  text-align: center;
}

.profile-mask {
  position: fixed;
  z-index: 990;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 42rpx;
  background: rgba(0, 0, 0, 0.34);
  box-sizing: border-box;
}

.profile-card {
  width: 88%;
  max-width: 560rpx;
  padding: 34rpx 28rpx 28rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.7);
  border-radius: 18rpx;
  background: #fff8e8;
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.48);
  box-sizing: border-box;
}

.profile-title,
.profile-body {
  display: block;
}

.profile-title {
  color: #8f1318;
  font-size: 32rpx;
  line-height: 1.18;
  font-weight: 1000;
  text-align: center;
}

.profile-body {
  margin-top: 16rpx;
  color: #1c1c1c;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 800;
}

.profile-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.profile-primary,
.profile-secondary,
.avatar-picker {
  min-width: 0;
  margin: 0;
  padding: 0;
  border-radius: 10rpx;
  font-size: 24rpx;
  line-height: 72rpx;
  font-weight: 1000;
}

.profile-primary::after,
.profile-secondary::after,
.avatar-picker::after {
  border: none;
}

.profile-primary {
  flex: 1.25;
  color: #fff;
  background: #8f1318;
}

.profile-secondary {
  flex: 1;
  color: #8f1318;
  background: rgba(143, 19, 24, 0.08);
}

.avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  margin: 24rpx auto 18rpx;
  overflow: hidden;
  border: 2rpx dashed rgba(143, 19, 24, 0.38);
  border-radius: 50%;
  color: #8f1318;
  background: rgba(143, 19, 24, 0.06);
  line-height: 1.2;
}

.avatar-preview {
  width: 132rpx;
  height: 132rpx;
}

.avatar-placeholder {
  width: 96rpx;
  color: #8f1318;
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 1000;
  text-align: center;
}

.nickname-input {
  height: 74rpx;
  padding: 0 20rpx;
  border: 2rpx solid rgba(143, 19, 24, 0.22);
  border-radius: 10rpx;
  color: #1a1a1a;
  font-size: 26rpx;
  font-weight: 800;
  background: #fff;
  box-sizing: border-box;
}

.warning-marquee {
  height: 54rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 64, 64, 0.42);
  border-radius: 14rpx;
  background: #210606;
  white-space: nowrap;
}

.warning-track {
  display: inline-block;
  padding-left: 100%;
  color: #ff3b30;
  font-size: 22rpx;
  line-height: 50rpx;
  font-weight: 1000;
  animation: warning-scroll 16s linear infinite;
}

@keyframes warning-scroll {
  to {
    transform: translateX(-100%);
  }
}

.sync-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 44rpx;
  margin: -2rpx 0 12rpx;
  color: #f4c766;
  font-size: 20rpx;
  font-weight: 900;
}

.sync-spinner {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid rgba(244, 199, 102, 0.28);
  border-top-color: #e80f16;
  border-radius: 50%;
  animation: sync-spin 0.8s linear infinite;
}

@keyframes sync-spin {
  to {
    transform: rotate(360deg);
  }
}

.hero {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 226rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #000;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
}

.hero-mark {
  flex: none;
  width: 142rpx;
  height: 142rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #000;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.28);
}

.hero-logo {
  width: 100%;
  height: 100%;
  background: #000;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.04;
  font-weight: 1000;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 21rpx;
  line-height: 1.34;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-version,
.hero-update,
.hero-model {
  display: block;
  margin-top: 5rpx;
  color: rgba(214, 170, 76, 0.86);
  font-size: 18rpx;
  line-height: 1.3;
  font-weight: 800;
}

.hero-model {
  color: rgba(255, 255, 255, 0.66);
}

.hero-update {
  color: rgba(255, 255, 255, 0.78);
}

.ticker {
  display: flex;
  gap: 14rpx;
  align-items: center;
  min-height: 68rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #121212;
}

.ticker-hot {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 20rpx;
  font-weight: 900;
}

.ticker-text {
  min-width: 0;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  line-height: 1.3;
}

.review-panel {
  margin-top: 12rpx;
  border-radius: 16rpx;
  background: #121212;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 70rpx;
  padding: 14rpx 18rpx;
}

.history-header {
  height: 78rpx;
}

.review-head-title {
  flex: none;
}

.history-title {
  width: 132rpx;
}

.review-title {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
}

.review-subtitle {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 19rpx;
}

.review-arrow {
  flex: none;
  width: 64rpx;
  text-align: right;
  color: #d6aa4c;
  font-size: 21rpx;
  font-weight: 900;
}

.review-head-chart {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 54rpx;
  padding: 0;
  border-radius: 10rpx;
  background: rgba(255, 77, 79, 0.06);
  overflow: hidden;
}

.history-mini-chart {
  height: 54rpx;
}

.mini-chart-shell {
  display: flex;
  align-items: stretch;
  gap: 6rpx;
  width: 100%;
  height: 54rpx;
  box-sizing: border-box;
}

.mini-y-axis {
  flex: none;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 34rpx;
  padding: 2rpx 0;
  color: rgba(255, 255, 255, 0.62);
  font-size: 13rpx;
  line-height: 1;
  font-weight: 800;
  text-align: right;
  box-sizing: border-box;
}

.review-list {
  padding: 0 18rpx 14rpx;
}

.review-chart {
  display: flex;
  gap: 12rpx;
  height: 170rpx;
  padding: 14rpx 0 18rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
}

.chart-y-axis {
  flex: none;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 54rpx;
  color: rgba(255, 255, 255, 0.48);
  font-size: 17rpx;
  font-weight: 800;
  line-height: 1;
}

.chart-area {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 100%;
}

.compact-chart-area {
  overflow: visible;
  padding-right: 44rpx;
  box-sizing: border-box;
}

.chart-grid {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.09);
}

.chart-grid-top {
  top: 0;
}

.chart-grid-mid {
  top: 50%;
}

.chart-grid-bottom {
  bottom: 0;
}

.chart-segment {
  position: absolute;
  height: 5rpx;
  border-radius: 999rpx;
  background: #ff3438;
  transform-origin: left center;
  box-shadow: 0 0 12rpx rgba(255, 52, 56, 0.58);
}

.compact-chart-segment {
  height: 4rpx;
}

.chart-column {
  position: absolute;
  bottom: 0;
  width: 8rpx;
  margin-left: -4rpx;
  border-radius: 999rpx 999rpx 0 0;
  background: rgba(255, 77, 79, 0.2);
}

.chart-point {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  margin-left: -7rpx;
  margin-bottom: -7rpx;
  border-radius: 50%;
  border: 3rpx solid #050505;
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.18);
}

.compact-chart-point {
  width: 9rpx;
  height: 9rpx;
  margin-left: -4.5rpx;
  margin-bottom: -4.5rpx;
  border: 0;
  background: #ff3438;
  box-shadow: 0 0 0 2rpx rgba(255, 52, 56, 0.16), 0 0 10rpx rgba(255, 52, 56, 0.72);
}

.mini-final-label {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: #ff4d4f;
  font-size: 15rpx;
  line-height: 1;
  font-weight: 1000;
  white-space: nowrap;
}

.review-item {
  display: block;
  padding: 12rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
}

.review-match {
  min-width: 0;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.review-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.review-percent {
  flex: none;
  min-width: 82rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 1000;
}

.percent-p100 {
  color: #29d66d;
  background: rgba(41, 214, 109, 0.12);
}

.percent-p75 {
  color: #facc15;
  background: rgba(250, 204, 21, 0.12);
}

.percent-p50 {
  color: #fb923c;
  background: rgba(251, 146, 60, 0.14);
}

.percent-p25,
.percent-p0 {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.12);
}

.chart-point.compact-chart-point,
.chart-point.compact-chart-point.percent-p100,
.chart-point.compact-chart-point.percent-p75,
.chart-point.compact-chart-point.percent-p50,
.chart-point.compact-chart-point.percent-p25,
.chart-point.compact-chart-point.percent-p0 {
  background: #ff3438;
}

.review-lines {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.review-line {
  display: inline-flex;
  align-items: center;
  gap: 7rpx;
  min-height: 38rpx;
  padding: 5rpx 0;
  border-radius: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  background: transparent;
  font-size: 20rpx;
  font-weight: 900;
}

.plain-review-line {
  width: 100%;
  min-width: 0;
}

.review-line .review-ok,
.review-line .review-bad {
  background: transparent;
  font-size: 20rpx;
  font-weight: 1000;
}

.review-value {
  flex: none;
  min-width: 44rpx;
  color: #fff;
  background: transparent;
  font-size: 22rpx;
  font-weight: 1000;
  line-height: 1.25;
  white-space: nowrap;
}

.review-divider {
  flex: none;
  color: rgba(255, 255, 255, 0.38);
  font-size: 18rpx;
  font-weight: 900;
}

.review-bracket {
  color: rgba(255, 255, 255, 0.54);
  background: transparent;
}

.review-ok {
  color: #29d66d;
  background: rgba(41, 214, 109, 0.12);
}

.review-bad {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.12);
}

.review-value.review-ok {
  color: #29d66d;
  background: transparent;
}

.review-value.review-bad {
  color: #ff4d4f;
  background: transparent;
}

.review-pick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
  margin-top: 10rpx;
}

.review-pick-cell {
  min-width: 0;
  padding: 8rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.055);
}

.review-pick-label {
  display: block;
  margin-bottom: 5rpx;
  color: rgba(255, 255, 255, 0.46);
  font-size: 17rpx;
  line-height: 1;
  font-weight: 850;
}

.review-pick-value {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  color: #fff;
  font-size: 21rpx;
  line-height: 1.18;
  font-weight: 1000;
  white-space: nowrap;
}

.review-pick-left .review-pick-value {
  justify-content: flex-start;
}

.review-pick-right .review-pick-value {
  justify-content: flex-end;
}

.review-pick-value .review-ok,
.review-pick-value .review-bad {
  background: transparent;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-pill {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 74rpx;
  height: 36rpx;
  min-height: 36rpx;
  padding: 0 14rpx;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 32rpx;
  font-weight: 1000;
}

.count-pill {
  color: #050505;
  background: #d6aa4c;
}

.history-entry {
  color: #fff;
  background: #e80f16;
  text-decoration: none;
}

.favorite-entry {
  text-decoration: none;
}

.favorite-entry-empty {
  color: #facc15;
  background: transparent;
  border-color: #facc15;
}

.favorite-entry-solid {
  color: #050505;
  background: #facc15;
  border-color: #facc15;
}

.favorite-entry-hover,
.history-entry-hover {
  opacity: 0.84;
}

.match-card {
  display: block;
  margin-bottom: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #121212;
}

.match-card-hover {
  transform: scale(0.99);
  opacity: 0.92;
}

.match-top,
.teams,
.prediction-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.match-meta-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.match-meta-copy {
  min-width: 0;
  flex: 1;
}

.favorite-button {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-top: -2rpx;
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.58);
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  font-size: 26rpx;
  line-height: 1;
  font-weight: 1000;
}

.favorite-button text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  transform: translate(0, -1rpx);
}

.favorite-on {
  color: #050505;
  background: #facc15;
  border-color: #ffe58a;
  box-shadow: 0 0 18rpx rgba(250, 204, 21, 0.42);
}

.date-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.altitude-tag {
  display: inline-flex;
  align-items: center;
  min-height: 32rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #07110a;
  font-size: 19rpx;
  font-weight: 1000;
}

.altitude-low {
  background: #4ade80;
}

.altitude-mid {
  background: #facc15;
}

.altitude-high {
  background: #fb923c;
}

.altitude-extreme {
  color: #fff;
  background: #ef4444;
}

.altitude-unknown {
  color: rgba(255, 255, 255, 0.76);
  background: #2a2a2a;
}

.venue {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
}

.arrow {
  color: #d6aa4c;
  font-size: 44rpx;
  font-weight: 300;
}

.teams {
  gap: 12rpx;
  margin-top: 14rpx;
}

.team {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  gap: 10rpx;
}

.team.right {
  justify-content: flex-end;
  text-align: right;
}

.flag-img {
  flex: none;
  width: 50rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.18);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.team-name {
  min-width: 0;
  flex: 1;
}

.team-title-line {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
}

.team.right .team-title-line {
  justify-content: flex-end;
}

.team.right .en {
  text-align: right;
}

.cn {
  flex: none;
  font-size: 27rpx;
  font-weight: 900;
}

.en {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: rgba(255, 255, 255, 0.66);
  font-size: 17rpx;
  font-weight: 800;
}

.team-profile {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  font-weight: 850;
}

.vs {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #050505;
  background: #fff;
  font-size: 19rpx;
  font-weight: 1000;
  line-height: 58rpx;
  text-align: center;
}

.match-status.status-live,
.match-status.status-finished {
  flex-direction: column;
  width: 82rpx;
  height: 74rpx;
  border-radius: 18rpx;
  color: #fff;
  font-size: 18rpx;
  line-height: 1.05;
}

.match-status.status-live {
  background: #e80f16;
  box-shadow: 0 10rpx 24rpx rgba(232, 15, 22, 0.28);
}

.match-status.status-finished {
  background: #16a34a;
  box-shadow: 0 10rpx 24rpx rgba(22, 163, 74, 0.26);
}

.live-score {
  display: block;
  margin-top: 5rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 1000;
}

.live-minute {
  display: block;
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 15rpx;
  font-weight: 850;
}

.prediction-strip {
  gap: 10rpx;
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.16);
  color: #d6aa4c;
  font-size: 20rpx;
  font-weight: 800;
}
