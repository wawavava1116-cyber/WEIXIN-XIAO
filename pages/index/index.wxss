.home-page {
  overflow: hidden;
}

.startup-mask {
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: #050505;
}

.startup-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  max-width: 520rpx;
  transform: translateY(-8vh);
}

.startup-logo-shell {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  overflow: hidden;
  border-radius: 26rpx;
  background: #000;
  box-shadow: 0 20rpx 44rpx rgba(0, 0, 0, 0.36);
}

.startup-logo {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 168rpx;
  height: 168rpx;
  margin: 6rpx;
  border-radius: 22rpx;
  background: #000;
}

.startup-logo-base {
  opacity: 0.18;
  filter: grayscale(1);
}

.startup-logo-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  transition: height 0.18s ease;
}

.startup-logo-active {
  opacity: 1;
}

.startup-percent {
  min-width: 48rpx;
  color: #fff;
  font-size: 17rpx;
  line-height: 1;
  font-weight: 1000;
  text-align: center;
}

.warning-marquee {
  height: 54rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 64, 64, 0.42);
  border-radius: 14rpx;
  background: #210606;
  white-space: nowrap;
}

.warning-track {
  display: inline-block;
  padding-left: 100%;
  color: #ff3b30;
  font-size: 22rpx;
  line-height: 50rpx;
  font-weight: 1000;
  animation: warning-scroll 16s linear infinite;
}

@keyframes warning-scroll {
  to {
    transform: translateX(-100%);
  }
}

.sync-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 44rpx;
  margin: -2rpx 0 12rpx;
  color: #f4c766;
  font-size: 20rpx;
  font-weight: 900;
}

.sync-spinner {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid rgba(244, 199, 102, 0.28);
  border-top-color: #e80f16;
  border-radius: 50%;
  animation: sync-spin 0.8s linear infinite;
}

@keyframes sync-spin {
  to {
    transform: rotate(360deg);
  }
}

.hero {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 226rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #000;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
}

.hero-mark {
  flex: none;
  width: 142rpx;
  height: 142rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #000;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.28);
}

.hero-logo {
  width: 100%;
  height: 100%;
  background: #000;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  line-height: 1.04;
  font-weight: 1000;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  line-height: 1.34;
}

.hero-version,
.hero-model {
  display: block;
  margin-top: 5rpx;
  color: rgba(214, 170, 76, 0.86);
  font-size: 18rpx;
  line-height: 1.3;
  font-weight: 800;
}

.hero-model {
  color: rgba(255, 255, 255, 0.66);
}

.ticker {
  display: flex;
  gap: 14rpx;
  align-items: center;
  min-height: 68rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #121212;
}

.ticker-hot {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 20rpx;
  font-weight: 900;
}

.ticker-text {
  min-width: 0;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  line-height: 1.3;
}

.review-panel {
  margin-top: 12rpx;
  border-radius: 16rpx;
  background: #121212;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 70rpx;
  padding: 14rpx 18rpx;
}

.review-title {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
}

.review-subtitle {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 19rpx;
}

.review-arrow {
  flex: none;
  color: #d6aa4c;
  font-size: 21rpx;
  font-weight: 900;
}

.review-list {
  padding: 0 18rpx 14rpx;
}

.review-item {
  display: block;
  padding: 12rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
}

.review-match {
  min-width: 0;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.review-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.review-percent {
  flex: none;
  min-width: 82rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 1000;
}

.percent-p100 {
  color: #29d66d;
  background: rgba(41, 214, 109, 0.12);
}

.percent-p75 {
  color: #facc15;
  background: rgba(250, 204, 21, 0.12);
}

.percent-p50 {
  color: #fb923c;
  background: rgba(251, 146, 60, 0.14);
}

.percent-p25,
.percent-p0 {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.12);
}

.review-lines {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.review-line {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 900;
}

.review-ok {
  color: #29d66d;
  background: rgba(41, 214, 109, 0.12);
}

.review-bad {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.12);
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.history-entry {
  color: #fff;
  background: #e80f16;
  text-decoration: none;
}

.favorite-entry {
  color: #050505;
  background: #facc15;
  text-decoration: none;
}

.favorite-entry-hover,
.history-entry-hover {
  opacity: 0.84;
}

.match-card {
  display: block;
  margin-bottom: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #121212;
}

.match-card-hover {
  transform: scale(0.99);
  opacity: 0.92;
}

.match-top,
.teams,
.prediction-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.match-meta-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.match-meta-copy {
  min-width: 0;
  flex: 1;
}

.favorite-button {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  margin-top: -2rpx;
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.58);
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  font-size: 26rpx;
  line-height: 1;
  font-weight: 1000;
}

.favorite-button text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  transform: translate(0, -1rpx);
}

.favorite-on {
  color: #050505;
  background: #facc15;
  border-color: #ffe58a;
  box-shadow: 0 0 18rpx rgba(250, 204, 21, 0.42);
}

.date-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.altitude-tag {
  display: inline-flex;
  align-items: center;
  min-height: 32rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #07110a;
  font-size: 19rpx;
  font-weight: 1000;
}

.altitude-low {
  background: #4ade80;
}

.altitude-mid {
  background: #facc15;
}

.altitude-high {
  background: #fb923c;
}

.altitude-extreme {
  color: #fff;
  background: #ef4444;
}

.altitude-unknown {
  color: rgba(255, 255, 255, 0.76);
  background: #2a2a2a;
}

.venue {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
}

.arrow {
  color: #d6aa4c;
  font-size: 44rpx;
  font-weight: 300;
}

.teams {
  gap: 12rpx;
  margin-top: 14rpx;
}

.team {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  gap: 10rpx;
}

.team.right {
  justify-content: flex-end;
  text-align: right;
}

.flag-img {
  flex: none;
  width: 50rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.18);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.team-name {
  min-width: 0;
  flex: 1;
}

.team-title-line {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  min-width: 0;
}

.team.right .team-title-line {
  justify-content: flex-end;
}

.team.right .en {
  text-align: right;
}

.cn {
  flex: none;
  font-size: 27rpx;
  font-weight: 900;
}

.en {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: rgba(255, 255, 255, 0.66);
  font-size: 17rpx;
  font-weight: 800;
}

.team-profile {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  font-weight: 850;
}

.vs {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #050505;
  background: #fff;
  font-size: 19rpx;
  font-weight: 1000;
  line-height: 58rpx;
  text-align: center;
}

.match-status.status-live,
.match-status.status-finished {
  flex-direction: column;
  width: 82rpx;
  height: 74rpx;
  border-radius: 18rpx;
  color: #fff;
  font-size: 18rpx;
  line-height: 1.05;
}

.match-status.status-live {
  background: #e80f16;
  box-shadow: 0 10rpx 24rpx rgba(232, 15, 22, 0.28);
}

.match-status.status-finished {
  background: #16a34a;
  box-shadow: 0 10rpx 24rpx rgba(22, 163, 74, 0.26);
}

.live-score {
  display: block;
  margin-top: 5rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 1000;
}

.live-minute {
  display: block;
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 15rpx;
  font-weight: 850;
}

.prediction-strip {
  gap: 10rpx;
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.16);
  color: #d6aa4c;
  font-size: 20rpx;
  font-weight: 800;
}
