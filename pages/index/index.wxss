.home-page {
  overflow: hidden;
}

.hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 226rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #0d0d0d;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
}

.hero::after {
  display: none;
}

.hero-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  margin-top: 0;
  font-size: 48rpx;
  line-height: 1.04;
  font-weight: 1000;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  line-height: 1.34;
}

.hero-mark {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: 192rpx;
  height: 194rpx;
}

.hero-logo {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 18rpx 22rpx rgba(0, 0, 0, 0.22));
}

.ticker {
  display: flex;
  gap: 14rpx;
  align-items: center;
  min-height: 68rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #121212;
}

.review-panel {
  margin-top: 12rpx;
  border-radius: 16rpx;
  background: #121212;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 70rpx;
  padding: 14rpx 18rpx;
}

.review-title {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
}

.review-subtitle {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 19rpx;
}

.review-arrow {
  flex: none;
  color: #d6aa4c;
  font-size: 21rpx;
  font-weight: 900;
}

.review-list {
  padding: 0 18rpx 14rpx;
}

.review-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
}

.review-match {
  min-width: 0;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.review-pick {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 18rpx;
  font-weight: 600;
}

.review-rate {
  flex: none;
  min-width: 116rpx;
  padding: 8rpx 10rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #050505;
  background: #d6aa4c;
  font-size: 19rpx;
  font-weight: 900;
}

.review-rate.near {
  color: #fff;
  background: #7b642e;
}

.review-rate.pending {
  color: rgba(255, 255, 255, 0.72);
  background: #2a2a2a;
}

.ticker-hot {
  flex: none;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 20rpx;
  font-weight: 900;
}

.ticker-text {
  min-width: 0;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  line-height: 1.3;
}

.match-card {
  display: block;
  margin-bottom: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  color: #fff;
  background: #121212;
}

.match-card-hover {
  transform: scale(0.99);
  opacity: 0.92;
}

.match-top,
.teams,
.prediction-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date {
  display: block;
  font-size: 25rpx;
  font-weight: 900;
}

.venue {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
}

.arrow {
  color: #d6aa4c;
  font-size: 44rpx;
  font-weight: 300;
}

.teams {
  gap: 12rpx;
  margin-top: 14rpx;
}

.team {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  gap: 10rpx;
}

.team.right {
  justify-content: flex-end;
  text-align: right;
}

.flag-img {
  flex: none;
  width: 50rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.18);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.team-name {
  min-width: 0;
}

.cn {
  display: block;
  font-size: 27rpx;
  font-weight: 900;
}

.en {
  display: block;
  margin-top: 3rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 18rpx;
}

.vs {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #050505;
  background: #fff;
  font-size: 19rpx;
  font-weight: 1000;
}

.prediction-strip {
  gap: 10rpx;
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.16);
  color: #d6aa4c;
  font-size: 20rpx;
  font-weight: 800;
}
