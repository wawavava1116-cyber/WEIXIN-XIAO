.prediction-page {
  padding-bottom: 28rpx;
}

.prediction-hero {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 160rpx;
  padding: 20rpx 22rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
  border-radius: 20rpx;
  background: #000;
}

.prediction-logo {
  flex: none;
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  background: #000;
}

.prediction-hero-copy {
  min-width: 0;
}

.prediction-kicker,
.prediction-title,
.prediction-badge {
  display: block;
}

.prediction-kicker {
  color: rgba(214, 170, 76, 0.94);
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 1000;
}

.prediction-title {
  margin-top: 8rpx;
  color: #fff;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 1000;
}

.prediction-badge {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.58);
  font-size: 18rpx;
  line-height: 1.25;
  font-weight: 900;
}

.prediction-section {
  margin-top: 20rpx;
}

.section-title-text {
  display: block;
  margin: 0 4rpx 12rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 1000;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.section-title-row .section-title-text {
  margin-bottom: 0;
}

.section-toggle {
  flex: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 42rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(214, 170, 76, 0.36);
  border-radius: 10rpx;
  color: #d6aa4c;
  background: rgba(214, 170, 76, 0.08);
  font-size: 19rpx;
  font-weight: 1000;
}

.section-toggle text:last-child {
  min-width: 30rpx;
  color: #050505;
  background: #d6aa4c;
  border-radius: 999rpx;
  text-align: center;
}

.prediction-match-panel {
  margin-bottom: 14rpx;
}

.fixture-row {
  display: grid;
  grid-template-columns: 1fr 1.08fr 1fr 26rpx;
  align-items: center;
  gap: 8rpx;
  min-height: 76rpx;
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  color: #fff;
}

.fixture-row.disabled {
  opacity: 0.58;
}

.fixture-hover {
  opacity: 0.92;
  transform: scale(0.99);
}

.fixture-team {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  font-size: 25rpx;
  font-weight: 1000;
}

.fixture-team.right {
  justify-content: flex-end;
}

.fixture-flag {
  width: 36rpx;
  height: 26rpx;
}

.fixture-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  line-height: 1.25;
  font-weight: 900;
  text-align: center;
}

.saved-text {
  color: #39d97b;
}

.fixture-arrow {
  color: #d6aa4c;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 300;
  text-align: right;
}

.empty-fixtures {
  padding: 22rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.auth-panel {
  margin-bottom: 12rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 900;
  text-align: center;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 16rpx;
  border-radius: 16rpx;
}

.stats-card > view {
  min-width: 0;
  padding: 12rpx 8rpx;
  border-radius: 12rpx;
  background: rgba(214, 170, 76, 0.1);
  text-align: center;
}

.stats-label,
.stats-value {
  display: block;
}

.stats-label {
  color: rgba(214, 170, 76, 0.86);
  font-size: 18rpx;
  font-weight: 1000;
}

.stats-value {
  margin-top: 8rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 1000;
}

.submitted-card {
  display: block;
  margin-top: 10rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  color: #fff;
}

.submitted-top,
.submitted-teams,
.submitted-picks {
  display: flex;
  align-items: center;
}

.submitted-top {
  justify-content: space-between;
  gap: 10rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 19rpx;
  font-weight: 900;
}

.settled-ok {
  color: #39d97b;
}

.settled-pending {
  color: rgba(214, 170, 76, 0.9);
}

.submitted-teams {
  justify-content: center;
  gap: 12rpx;
  margin-top: 10rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 1000;
}

.submitted-teams text:nth-child(2) {
  color: rgba(214, 170, 76, 0.8);
  font-size: 20rpx;
}

.submitted-picks {
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 12rpx;
}

.submitted-picks text {
  flex: 1;
  min-width: 0;
  padding: 9rpx 8rpx;
  border-radius: 10rpx;
  color: #050505;
  background: rgba(214, 170, 76, 0.92);
  font-size: 20rpx;
  line-height: 1.15;
  font-weight: 1000;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-submitted-card .submitted-teams text {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 27rpx;
}

.group-create {
  padding: 16rpx;
  border-radius: 16rpx;
}

.group-size-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 10rpx;
  row-gap: 8rpx;
  width: 100%;
}

.group-size-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 58rpx;
  border: 1rpx solid rgba(214, 170, 76, 0.24);
  border-radius: 12rpx;
  color: #fff;
  background: #141414;
  font-size: 24rpx;
  font-weight: 1000;
  text-align: center;
}

.group-size-chip text {
  display: block;
  width: 100%;
  text-align: center;
  line-height: 1.1;
}

.group-size-chip.selected,
.group-match-option.selected {
  color: #050505;
  border-color: #d6aa4c;
  background: #d6aa4c;
}

.group-create-title {
  display: block;
  margin: 18rpx 4rpx 10rpx;
  color: rgba(214, 170, 76, 0.86);
  font-size: 22rpx;
  font-weight: 1000;
}

.group-match-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.group-match-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-height: 60rpx;
  padding: 10rpx 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 10rpx;
  color: #fff;
  background: #111;
  font-size: 21rpx;
  font-weight: 1000;
}

.group-match-option text:last-child {
  color: rgba(255, 255, 255, 0.58);
  font-size: 18rpx;
}

.group-match-option.selected text:last-child {
  color: rgba(5, 5, 5, 0.66);
}

.group-create-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 26rpx;
  font-weight: 1000;
}

.group-card {
  display: block;
  margin-top: 10rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  color: #fff;
}

.group-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  font-size: 25rpx;
  font-weight: 1000;
}

.group-card-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.group-card-actions text {
  color: #d6aa4c;
}

.group-delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 74rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(214, 170, 76, 0.42);
  border-radius: 8rpx;
  color: #d6aa4c;
  background: rgba(214, 170, 76, 0.08);
  font-size: 20rpx;
  line-height: 1;
  font-weight: 1000;
}

.group-card-sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  font-weight: 900;
}
