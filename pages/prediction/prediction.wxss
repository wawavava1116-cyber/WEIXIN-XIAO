.prediction-page {
  padding-bottom: 28rpx;
}

.simple-hero {
  padding: 26rpx 24rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
  border-radius: 22rpx;
  background: #101010;
}

.simple-title {
  display: block;
  font-size: 46rpx;
  line-height: 1.08;
  font-weight: 1000;
}

.simple-subtitle,
.simple-badge {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 800;
}

.simple-badge {
  color: rgba(214, 170, 76, 0.86);
  font-size: 18rpx;
}

.prediction-card {
  display: block;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  color: #fff;
}

.prediction-card-hover {
  opacity: 0.92;
  transform: scale(0.99);
}

.prediction-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 21rpx;
  font-weight: 900;
}

.prediction-head text:last-child {
  color: #fff;
  font-size: 30rpx;
  font-weight: 1000;
}

.prediction-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
}

.prediction-grid > view {
  min-width: 0;
  padding: 12rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(214, 170, 76, 0.1);
}

.prediction-label,
.prediction-value {
  display: block;
  text-align: center;
}

.prediction-label {
  color: rgba(214, 170, 76, 0.9);
  font-size: 18rpx;
  font-weight: 1000;
}

.prediction-value {
  margin-top: 6rpx;
  color: #fff;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 1000;
}

.prediction-risk {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 800;
}
