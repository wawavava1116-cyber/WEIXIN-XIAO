<view class="safe-page prediction-page" bindtouchstart="onPageTouchStart" bindtouchend="onPageTouchEnd">
  <view class="prediction-hero">
    <image class="prediction-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
    <view class="prediction-hero-copy">
      <text class="prediction-kicker">MY WORLD CUP PICKS</text>
      <text class="prediction-title">我的预测</text>
      <text class="prediction-badge">{{databaseBadge}}</text>
    </view>
  </view>

  <view class="prediction-section">
    <view class="section-title-row">
      <text class="section-title-text">已经预测</text>
    </view>
    <view class="prediction-match-panel">
      <view class="auth-panel glass" wx:if="{{!canPredict}}">
        <text>{{authMessage}}</text>
      </view>
      <block wx:if="{{matches.length}}">
        <block wx:for="{{matches}}" wx:key="id">
          <navigator wx:if="{{canPredict}}" class="fixture-row glass" url="{{item.formPath}}" hover-class="fixture-hover">
            <view class="fixture-team">
              <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
              <text>{{item.home.abbr}}</text>
            </view>
            <view class="fixture-time">
              <text>{{item.dateText}}</text>
              <text>{{item.kickoff}}</text>
              <text wx:if="{{item.savedText}}" class="saved-text">{{item.savedText}}</text>
            </view>
            <view class="fixture-team right">
              <text>{{item.away.abbr}}</text>
              <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
            </view>
            <text class="fixture-arrow">›</text>
          </navigator>
          <view wx:else class="fixture-row glass disabled">
            <view class="fixture-team">
              <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
              <text>{{item.home.abbr}}</text>
            </view>
            <view class="fixture-time">
              <text>{{item.dateText}}</text>
              <text>{{item.kickoff}}</text>
            </view>
            <view class="fixture-team right">
              <text>{{item.away.abbr}}</text>
              <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
            </view>
            <text class="fixture-arrow">›</text>
          </view>
        </block>
      </block>
      <view class="empty-fixtures glass" wx:else>
        <text>今天和明天暂无可预测的未开赛比赛</text>
      </view>
    </view>
    <view class="stats-card glass" wx:if="{{canPredict}}">
      <view>
        <text class="stats-label">近10次准确率</text>
        <text class="stats-value">{{predictionStats.accuracy}}</text>
      </view>
      <view>
        <text class="stats-label">全站排名</text>
        <text class="stats-value">{{predictionStats.rank ? predictionStats.rank : '--'}}</text>
      </view>
      <view>
        <text class="stats-label">已结算</text>
        <text class="stats-value">{{predictionStats.settledCount || 0}}场</text>
      </view>
    </view>
    <view class="submitted-toggle glass" wx:if="{{canPredict}}" bindtap="toggleSubmittedRecords">
      <view>
        <text class="submitted-toggle-title">已预测内容</text>
        <text class="submitted-toggle-sub">{{submittedRecordCount}} 条</text>
      </view>
      <text class="submitted-toggle-action">{{showSubmittedRecords ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{showSubmittedRecords}}">
      <block wx:if="{{canPredict && submittedPredictions.length}}">
        <block wx:for="{{submittedPredictions}}" wx:key="id">
          <navigator class="submitted-card glass" url="/pages/predictionResult/predictionResult?id={{item.id}}" hover-class="fixture-hover">
            <view class="submitted-top">
              <text>{{item.dateText}} · {{item.kickoff}}</text>
              <text class="{{item.settled ? 'settled-ok' : 'settled-pending'}}">{{item.percent}}</text>
            </view>
            <view class="submitted-teams">
              <text>{{item.home.abbr}}</text>
              <text>vs</text>
              <text>{{item.away.abbr}}</text>
            </view>
            <view class="submitted-picks">
              <text>{{item.resultText}}</text>
              <text>{{item.scoreText}}</text>
              <text>{{item.goalsText}}</text>
            </view>
          </navigator>
        </block>
      </block>
      <block wx:if="{{canPredict && groupSubmittedPredictions.length}}">
        <block wx:for="{{groupSubmittedPredictions}}" wx:key="id">
          <navigator class="submitted-card group-submitted-card glass" url="{{item.path}}" hover-class="fixture-hover">
            <view class="submitted-top">
              <text>{{item.dateText}} · {{item.kickoff}}</text>
              <text class="settled-pending">{{item.progressText}}</text>
            </view>
            <view class="submitted-teams">
              <text>{{item.titleText}}</text>
            </view>
            <view class="submitted-picks">
              <text>{{item.matchText}}</text>
              <text>{{item.stateText}}</text>
              <text>可修改</text>
            </view>
          </navigator>
        </block>
      </block>
      <view class="empty-fixtures glass" wx:if="{{canPredict && !submittedPredictions.length && !groupSubmittedPredictions.length}}">
        <text>暂无已提交预测</text>
      </view>
    </view>
  </view>

  <view class="prediction-section">
    <text class="section-title-text">发起预测小组</text>
    <view class="auth-panel glass" wx:if="{{!canPredict}}">
      <text>完成微信身份和昵称后才能发起或加入预测小组。</text>
    </view>
    <view class="group-create glass" wx:else>
      <view class="group-size-row">
        <block wx:for="{{groupSizeOptions}}" wx:key="value">
          <view class="group-size-chip {{item.selected ? 'selected' : ''}}" data-value="{{item.value}}" bindtap="selectGroupSize">
            <text>{{item.value}}人</text>
          </view>
        </block>
      </view>
      <text class="group-create-title">选择预测比赛</text>
      <view class="group-match-list">
        <block wx:for="{{groupMatchOptions}}" wx:key="id">
          <view class="group-match-option {{item.selected ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="toggleGroupMatch">
            <text>{{item.home.abbr}} vs {{item.away.abbr}}</text>
            <text>{{item.dateText}} {{item.kickoff}}</text>
          </view>
        </block>
      </view>
      <button class="group-create-button" bindtap="createGroup">发起小组预测</button>
    </view>
  </view>

  <view class="prediction-section" wx:if="{{canPredict}}">
    <text class="section-title-text">我的小组</text>
    <block wx:if="{{groups.length}}">
      <block wx:for="{{groups}}" wx:key="id">
        <view class="group-card glass" data-id="{{item.id}}" bindtap="openGroup">
          <view class="group-card-top">
            <text>{{item.size}}人预测小组</text>
            <view class="group-card-actions">
              <text>{{item.progressText}}</text>
              <view wx:if="{{item.canDelete}}" class="group-delete-button" data-id="{{item.id}}" catchtap="deleteGroup">删除</view>
            </view>
          </view>
          <text class="group-card-sub">{{item.matches.length}} 场比赛 · {{item.allSettled ? '已结算' : (item.allPredicted ? '等待赛果' : '等待预测')}}</text>
        </view>
      </block>
    </block>
    <view class="empty-fixtures glass" wx:else>
      <text>暂无参与的小组预测</text>
    </view>
  </view>
</view>
