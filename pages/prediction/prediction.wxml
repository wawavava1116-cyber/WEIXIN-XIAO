<view class="safe-page prediction-page">
  <view class="prediction-hero">
    <image class="prediction-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
    <view class="prediction-hero-copy">
      <text class="prediction-kicker">MY WORLD CUP PICKS</text>
      <text class="prediction-title">我的预测</text>
      <text class="prediction-badge">{{databaseBadge}}</text>
    </view>
  </view>

  <view class="prediction-section">
    <text class="section-title-text">今天和明天未开赛比赛</text>
    <view class="auth-panel glass" wx:if="{{!canPredict}}">
      <text>{{authMessage}}</text>
    </view>
    <block wx:if="{{matches.length}}">
      <block wx:for="{{matches}}" wx:key="id">
        <navigator wx:if="{{canPredict}}" class="fixture-row glass" url="{{item.formPath}}" hover-class="fixture-hover">
          <view class="fixture-team">
            <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
            <text>{{item.home.abbr}}</text>
          </view>
          <view class="fixture-time">
            <text>{{item.dateText}}</text>
            <text>{{item.kickoff}}</text>
            <text wx:if="{{item.savedText}}" class="saved-text">{{item.savedText}}</text>
          </view>
          <view class="fixture-team right">
            <text>{{item.away.abbr}}</text>
            <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
          </view>
          <text class="fixture-arrow">›</text>
        </navigator>
        <view wx:else class="fixture-row glass disabled">
          <view class="fixture-team">
            <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
            <text>{{item.home.abbr}}</text>
          </view>
          <view class="fixture-time">
            <text>{{item.dateText}}</text>
            <text>{{item.kickoff}}</text>
          </view>
          <view class="fixture-team right">
            <text>{{item.away.abbr}}</text>
            <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
          </view>
          <text class="fixture-arrow">›</text>
        </view>
      </block>
    </block>
    <view class="empty-fixtures glass" wx:else>
      <text>今天和明天暂无可预测的未开赛比赛</text>
    </view>
  </view>

  <view class="prediction-section">
    <text class="section-title-text">已经预测</text>
    <view class="stats-card glass" wx:if="{{canPredict}}">
      <view>
        <text class="stats-label">近10次准确率</text>
        <text class="stats-value">{{predictionStats.accuracy}}</text>
      </view>
      <view>
        <text class="stats-label">全站排名</text>
        <text class="stats-value">{{predictionStats.rank ? predictionStats.rank : '--'}}</text>
      </view>
      <view>
        <text class="stats-label">已结算</text>
        <text class="stats-value">{{predictionStats.settledCount || 0}}场</text>
      </view>
    </view>
    <block wx:if="{{canPredict && submittedPredictions.length}}">
      <block wx:for="{{submittedPredictions}}" wx:key="id">
        <navigator class="submitted-card glass" url="/pages/predictionResult/predictionResult?id={{item.id}}" hover-class="fixture-hover">
          <view class="submitted-top">
            <text>{{item.dateText}} · {{item.kickoff}}</text>
            <text class="{{item.settled ? 'settled-ok' : 'settled-pending'}}">{{item.percent}}</text>
          </view>
          <view class="submitted-teams">
            <text>{{item.home.abbr}}</text>
            <text>vs</text>
            <text>{{item.away.abbr}}</text>
          </view>
          <view class="submitted-picks">
            <text>{{item.resultText}}</text>
            <text>{{item.scoreText}}</text>
            <text>{{item.goalsText}}</text>
          </view>
        </navigator>
      </block>
    </block>
    <view class="empty-fixtures glass" wx:elif="{{canPredict}}">
      <text>暂无已提交预测</text>
    </view>
  </view>
</view>
