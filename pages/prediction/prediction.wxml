<view class="safe-page prediction-page">
  <view class="prediction-hero">
    <image class="prediction-logo" src="/assets/brand/worldcup26-logo-black.png" mode="aspectFit"></image>
    <view class="prediction-hero-copy">
      <text class="prediction-kicker">MY WORLD CUP PICKS</text>
      <text class="prediction-title">我的预测</text>
      <text class="prediction-badge">{{databaseBadge}}</text>
    </view>
  </view>

  <view class="prediction-section">
    <text class="section-title-text">今天和明天未开赛比赛</text>
    <block wx:if="{{matches.length}}">
      <block wx:for="{{matches}}" wx:key="id">
        <navigator class="fixture-row glass" url="{{item.formPath}}" hover-class="fixture-hover">
          <view class="fixture-team">
            <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
            <text>{{item.home.abbr}}</text>
          </view>
          <view class="fixture-time">
            <text>{{item.dateText}}</text>
            <text>{{item.kickoff}}</text>
            <text wx:if="{{item.savedText}}" class="saved-text">{{item.savedText}}</text>
          </view>
          <view class="fixture-team right">
            <text>{{item.away.abbr}}</text>
            <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
          </view>
          <text class="fixture-arrow">›</text>
        </navigator>
      </block>
    </block>
    <view class="empty-fixtures glass" wx:else>
      <text>今天和明天暂无可预测的未开赛比赛</text>
    </view>
  </view>
</view>
