.profile-page {
  padding-bottom: 28rpx;
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
}

.profile-avatar {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  min-width: 86rpx;
  max-width: 86rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  background: #d7dce3;
  box-sizing: border-box;
}

.avatar-edit-button {
  margin: 0;
  padding: 0;
  width: 86rpx;
  height: 86rpx;
  min-width: 86rpx;
  max-width: 86rpx;
  min-height: 86rpx;
  max-height: 86rpx;
  border-radius: 50%;
  font-size: 0;
  line-height: 0;
  box-sizing: border-box;
  background: #d7dce3;
}

.avatar-edit-button::after {
  border: none;
}

.profile-avatar image {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
}

.avatar-silhouette {
  position: relative;
  width: 54rpx;
  height: 54rpx;
}

.avatar-head {
  position: absolute;
  left: 17rpx;
  top: 5rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #7c858f;
}

.avatar-body {
  position: absolute;
  left: 6rpx;
  bottom: 4rpx;
  width: 42rpx;
  height: 24rpx;
  border-radius: 22rpx 22rpx 8rpx 8rpx;
  background: #7c858f;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.profile-name {
  display: inline-block;
  max-width: 100%;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.15;
  font-weight: 1000;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  margin-top: 6rpx;
}

.profile-inline-edit {
  flex: none;
  padding: 3rpx 9rpx;
  border: 1rpx solid rgba(214, 170, 76, 0.34);
  border-radius: 999rpx;
  color: #d6aa4c;
  background: rgba(214, 170, 76, 0.08);
  font-size: 17rpx;
  line-height: 1.2;
  font-weight: 1000;
}

.profile-mode {
  display: inline-block;
  color: rgba(214, 170, 76, 0.88);
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1.2;
}

.profile-edit-tip {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.54);
  font-size: 17rpx;
  line-height: 1.3;
  font-weight: 800;
}

.profile-card {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 14rpx;
}

.profile-card-title,
.profile-card-text {
  display: block;
}

.profile-card-title {
  color: #d6aa4c;
  font-size: 22rpx;
  font-weight: 1000;
}

.profile-card-text {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 20rpx;
  line-height: 1.42;
  font-weight: 800;
}

.profile-functional-navigator {
  display: block;
}

.profile-login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
  margin: 14rpx 0 0;
  padding: 0;
  border-radius: 12rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 22rpx;
  line-height: 60rpx;
  font-weight: 1000;
}

.profile-secondary-button {
  color: #d6aa4c;
  background: rgba(214, 170, 76, 0.1);
  border: 2rpx solid rgba(214, 170, 76, 0.34);
}

.profile-login-button::after,
.avatar-picker::after {
  border: none;
}

.wechat-profile-form {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
}

.avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  margin: 18rpx auto;
  padding: 0;
  overflow: hidden;
  border: 2rpx dashed rgba(214, 170, 76, 0.45);
  border-radius: 50%;
  color: #d6aa4c;
  background: rgba(214, 170, 76, 0.08);
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 1000;
}

.avatar-preview {
  width: 132rpx;
  height: 132rpx;
}

.avatar-placeholder {
  width: 90rpx;
  text-align: center;
}

.nickname-input {
  height: 62rpx;
  padding: 0 16rpx;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
  border-radius: 12rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.08);
  font-size: 22rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.medal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 10rpx;
}

.medal-cell {
  min-width: 0;
  padding: 10rpx 8rpx;
  border-radius: 9rpx;
  text-align: center;
}

.medal-cell text {
  display: block;
}

.medal-cell text:first-child {
  color: rgba(5, 5, 5, 0.72);
  font-size: 16rpx;
  font-weight: 1000;
}

.medal-cell text:last-child {
  margin-top: 5rpx;
  color: #050505;
  font-size: 26rpx;
  line-height: 1;
  font-weight: 1000;
}

.medal-cell.gold {
  background: #d6aa4c;
}

.medal-cell.silver {
  background: #cfd6df;
}

.medal-cell.bronze {
  background: #c98b52;
}
