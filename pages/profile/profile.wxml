<view class="safe-page profile-page">
  <view class="profile-hero glass">
    <button class="profile-avatar avatar-edit-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{profile.avatarUrl}}" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar-silhouette">
        <view class="avatar-head"></view>
        <view class="avatar-body"></view>
      </view>
    </button>
    <view class="profile-copy">
      <view class="profile-name-row">
        <text class="profile-name" bindtap="showManualProfileForm">{{profile.nickname}}</text>
        <text wx:if="{{profile.canEditProfile && !showProfileForm}}" class="profile-inline-edit" bindtap="showManualProfileForm">修改昵称</text>
      </view>
      <text class="profile-mode">{{profile.modeText}}</text>
      <text class="profile-edit-tip" wx:if="{{profile.canEditProfile}}">点击头像或昵称可修改资料</text>
    </view>
  </view>

  <view class="profile-card glass">
    <text class="profile-card-title">账号状态</text>
    <text class="profile-card-text">{{profile.statusText}}</text>
    <button wx:if="{{profile.canLogin && !showProfileForm}}" class="profile-login-button" loading="{{savingProfile}}" bindtap="oneTapWechatLogin">微信一键登录</button>
    <view wx:if="{{showProfileForm}}" class="wechat-profile-form">
      <text class="profile-card-text">选择微信昵称，或输入自定义昵称。</text>
      <input class="nickname-input" type="nickname" placeholder="选择或输入昵称" value="{{profileNickname}}" bindinput="onProfileNicknameInput" bindchange="onProfileNicknameInput" />
      <button class="profile-login-button" loading="{{savingProfile}}" bindtap="saveWechatProfile">保存资料</button>
    </view>
  </view>

  <view class="profile-card glass">
    <text class="profile-card-title">预测小组奖牌</text>
    <view class="medal-grid">
      <view class="medal-cell gold">
        <text>金牌</text>
        <text>{{medals.gold || 0}}</text>
      </view>
      <view class="medal-cell silver">
        <text>银牌</text>
        <text>{{medals.silver || 0}}</text>
      </view>
      <view class="medal-cell bronze">
        <text>铜牌</text>
        <text>{{medals.bronze || 0}}</text>
      </view>
    </view>
  </view>

  <view class="profile-card glass">
    <text class="profile-card-title">使用说明</text>
    <text class="profile-card-text">微信一键登录只用于建立用户 ID。头像和昵称可以稍后手动选择或修改，预测记录会继续保存在同一个用户档案下。</text>
  </view>
</view>
