<view class="safe-page group-page">
  <block wx:if="{{group}}">
    <view class="group-hero glass">
      <text class="group-kicker">GROUP PICKS</text>
      <text class="group-title">{{group.size}}人预测小组</text>
      <view class="group-progress">
        <text>{{group.progressText}}</text>
        <text>{{statusText}}</text>
      </view>
      <button class="join-button" wx:if="{{canPredict && !group.currentUserJoined}}" bindtap="joinGroup">加入小组</button>
      <text class="group-auth" wx:elif="{{!canPredict}}">完成微信身份和昵称后才能加入并预测</text>
    </view>

    <view class="group-section">
      <text class="section-title-text">成员</text>
      <block wx:for="{{members}}" wx:key="userId">
        <view class="member-row glass">
          <view class="member-profile">
            <image wx:if="{{item.user.avatarUrl}}" src="{{item.user.avatarUrl}}" mode="aspectFill"></image>
            <text wx:else>人</text>
          </view>
          <view class="member-copy">
            <text>{{item.user.nickname || '微信用户'}}</text>
            <text>{{item.done ? '已预测' : '未预测'}}</text>
          </view>
          <view class="member-rank">
            <text wx:if="{{item.rank}}">第{{item.rank}}</text>
            <text wx:if="{{item.medalText}}">{{item.medalText}}</text>
            <text wx:if="{{item.settledCount}}">{{item.accuracy}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="group-section" wx:if="{{canPredict && group.currentUserJoined && !group.allSettled}}">
      <text class="section-title-text">{{group.currentUserDone ? '修改小组预测' : '填写小组预测'}}</text>
      <block wx:for="{{group.matchForms}}" wx:key="matchId">
        <view class="match-form glass">
          <view class="match-form-head" data-match-id="{{item.matchId}}" bindtap="toggleMatchForm">
            <view class="fixture-row">
              <view class="fixture-team">
                <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
                <view>
                  <text class="fixture-abbr">{{item.home.abbr}}</text>
                  <text class="fixture-name">{{item.home.cn}}</text>
                </view>
              </view>
              <view class="fixture-time">
                <text>{{item.dateText}}</text>
                <text>{{item.kickoff}}</text>
                <text>VS</text>
              </view>
              <view class="fixture-team right">
                <view>
                  <text class="fixture-abbr">{{item.away.abbr}}</text>
                  <text class="fixture-name">{{item.away.cn}}</text>
                </view>
                <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
              </view>
            </view>
            <view wx:if="{{item.canCollapse}}" class="match-toggle">{{item.toggleText}}</view>
          </view>

          <view class="match-form-body" wx:if="{{!item.collapsed}}">
          <text class="pick-title">胜平负</text>
          <view class="option-row">
            <block wx:for="{{item.resultOptions}}" wx:for-item="option" wx:key="value">
              <view class="pick-chip {{option.selected ? 'selected' : ''}}" data-match-id="{{item.matchId}}" data-value="{{option.value}}" bindtap="selectResult">
                <text>{{option.value}}</text>
              </view>
            </block>
          </view>

          <text class="pick-title">备选胜平负 <text class="pick-note">可选</text></text>
          <view class="option-row">
            <block wx:for="{{item.backupOptions}}" wx:for-item="option" wx:key="value">
              <view class="pick-chip {{option.selected ? 'selected' : ''}}" data-match-id="{{item.matchId}}" data-value="{{option.value}}" bindtap="selectBackup">
                <text>{{option.value}}</text>
              </view>
            </block>
          </view>

          <text class="pick-title">比分 <text class="pick-note">选择 2 个</text></text>
          <block wx:for="{{item.scoreGroups}}" wx:for-item="scoreGroup" wx:key="key">
            <text class="score-group-title">{{scoreGroup.title}}</text>
            <view class="score-grid">
              <block wx:for="{{scoreGroup.options}}" wx:for-item="score" wx:key="value">
                <view class="score-card {{score.selected ? 'selected' : ''}}" data-match-id="{{item.matchId}}" data-value="{{score.value}}" bindtap="selectScore">
                  <text>{{score.value}}</text>
                </view>
              </block>
            </view>
          </block>

          <text class="pick-title">进球数</text>
          <view class="goal-grid">
            <block wx:for="{{item.goalOptions}}" wx:for-item="option" wx:key="value">
              <view class="pick-chip {{option.selected ? 'selected' : ''}}" data-match-id="{{item.matchId}}" data-value="{{option.value}}" bindtap="selectGoals">
                <text>{{option.value}}</text>
              </view>
            </block>
          </view>
          </view>
        </view>
      </block>
      <button class="submit-button" bindtap="submitGroup">{{group.currentUserDone ? '更新小组预测' : '提交小组预测'}}</button>
    </view>

    <view class="group-section" wx:else>
      <text class="section-title-text">比赛</text>
      <block wx:for="{{group.matches}}" wx:key="matchId">
        <view class="match-summary glass">
          <view class="fixture-team">
            <image class="fixture-flag" src="{{item.home.flag}}" mode="aspectFit"></image>
            <text class="fixture-abbr">{{item.home.abbr}}</text>
          </view>
          <view class="fixture-time">
            <text>{{item.dateText}}</text>
            <text>{{item.kickoff}}</text>
          </view>
          <view class="fixture-team right">
            <text class="fixture-abbr">{{item.away.abbr}}</text>
            <image class="fixture-flag" src="{{item.away.flag}}" mode="aspectFit"></image>
          </view>
        </view>
      </block>
    </view>
  </block>
</view>
