<view class="safe-page detail-page" wx:if="{{match}}">
  <view class="detail-hero">
    <view class="meta-line">
      <text>{{match.dateText}} · {{match.kickoff}} · {{match.group}}</text>
      <text>{{match.weatherIcon}} {{match.weather}}</text>
      <text class="altitude altitude-{{match.altitudeLevel}}">⛰ {{match.altitude}}</text>
    </view>

    <view class="scoreline">
      <view class="side">
        <image class="big-flag" src="{{match.home.flag}}" mode="aspectFit"></image>
        <view class="side-title-line">
          <text class="side-cn">{{match.home.cn}}</text>
          <text class="side-en">{{match.home.en}}</text>
        </view>
        <text class="side-profile">FIFA {{match.home.rank}} · {{match.home.value}}</text>
      </view>

      <view class="score-core score-core-{{scorePanel.mode}}">
        <text class="score-eyebrow">{{scorePanel.eyebrow}}</text>
        <text class="score">{{scorePanel.score}}</text>
        <text class="score-predict">{{scorePanel.subLabel}} {{scorePanel.subScore}}</text>
      </view>

      <view class="side">
        <image class="big-flag" src="{{match.away.flag}}" mode="aspectFit"></image>
        <view class="side-title-line side-title-right">
          <text class="side-en">{{match.away.en}}</text>
          <text class="side-cn">{{match.away.cn}}</text>
        </view>
        <text class="side-profile">FIFA {{match.away.rank}} · {{match.away.value}}</text>
      </view>
    </view>

    <view class="venue-row">
      <text>{{match.venue}}</text>
      <text>{{match.pick.result}}</text>
    </view>
  </view>

  <view class="probability-card glass" wx:if="{{scorePanel.mode === 'pending' && match.analysis.probability}}">
    <view class="probability-section">
      <text class="block-title">胜平负概率占比</text>
      <view class="result-probability-bar">
        <block wx:for="{{match.analysis.probability.result}}" wx:key="key">
          <view class="result-segment probability-{{item.level}} {{item.isSmall ? 'segment-small' : ''}}" style="width: {{item.value}}%;">
            <text class="segment-percent">{{item.value}}%</text>
          </view>
        </block>
      </view>
    </view>

    <view class="probability-section">
      <text class="block-title">预期进球概率占比</text>
      <view class="goal-probability-grid">
        <view class="goal-team goal-team-left">
          <text class="goal-team-name">{{match.analysis.probability.goals.home.team}}</text>
          <view class="stacked-probability-bar">
            <block wx:for="{{match.analysis.probability.goals.home.items}}" wx:key="key">
              <view class="result-segment probability-{{item.level}} {{item.isSmall ? 'segment-small' : ''}}" style="width: {{item.value}}%;">
                <text class="segment-percent">{{item.value}}%</text>
              </view>
            </block>
          </view>
          <view class="goal-axis">
            <block wx:for="{{match.analysis.probability.goals.home.items}}" wx:key="key">
              <text style="width: {{item.value}}%;">{{item.label}}</text>
            </block>
          </view>
        </view>

        <view class="goal-team goal-team-right">
          <text class="goal-team-name">{{match.analysis.probability.goals.away.team}}</text>
          <view class="stacked-probability-bar">
            <block wx:for="{{match.analysis.probability.goals.away.items}}" wx:key="key">
              <view class="result-segment probability-{{item.level}} {{item.isSmall ? 'segment-small' : ''}}" style="width: {{item.value}}%;">
                <text class="segment-percent">{{item.value}}%</text>
              </view>
            </block>
          </view>
          <view class="goal-axis">
            <block wx:for="{{match.analysis.probability.goals.away.items}}" wx:key="key">
              <text style="width: {{item.value}}%;">{{item.label}}</text>
            </block>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="conclusion glass">
    <text class="block-title">综合结论</text>
    <text class="conclusion-text">{{match.analysis.conclusion}}</text>
  </view>

  <view class="market-grid">
    <view class="market-card glass">
      <text class="market-label">胜平负</text>
      <text class="market-value">{{match.analysis.market.oneXtwo}}</text>
    </view>
    <view class="market-card glass">
      <text class="market-label">亚盘</text>
      <text class="market-value">{{match.analysis.market.handicap}}</text>
    </view>
    <view class="market-card glass">
      <text class="market-label">大小球</text>
      <text class="market-value">{{match.analysis.market.total}}</text>
    </view>
  </view>

  <view class="analysis-card glass">
    <text class="block-title">球队状态</text>
    <text class="body-line">{{match.home.cn}}：{{match.analysis.form.home}}</text>
    <text class="body-line">{{match.away.cn}}：{{match.analysis.form.away}}</text>
  </view>

  <view class="analysis-card glass">
    <text class="block-title">伤停与预计阵容</text>
    <text class="body-line">{{match.home.cn}}：{{match.analysis.news.home}}</text>
    <text class="body-line">{{match.away.cn}}：{{match.analysis.news.away}}</text>
  </view>

  <view class="analysis-card glass" wx:if="{{match.analysis.injuryImpact}}">
    <text class="block-title">球员伤停信息及影响</text>
    <text class="body-line">{{match.home.cn}}：{{match.analysis.injuryImpact.home}}</text>
    <text class="body-line">{{match.away.cn}}：{{match.analysis.injuryImpact.away}}</text>
  </view>

  <view class="analysis-card glass">
    <text class="block-title">战术与比赛环境</text>
    <text class="body-line">{{match.analysis.tactics}}</text>
  </view>

  <view class="analysis-card glass">
    <text class="block-title">交锋参考</text>
    <text class="body-line">{{match.analysis.h2h}}</text>
  </view>

  <view class="final-card">
    <text class="block-title dark">最终倾向</text>
    <view class="lean-row"><text>胜平负首选</text><text>{{match.pick.result}}</text></view>
    <view class="lean-row"><text>胜平负备选</text><text>{{match.pick.resultBackup || '无'}}</text></view>
    <view class="lean-row"><text>主比分</text><text>{{match.pick.score}}</text></view>
    <view class="lean-row"><text>备用比分</text><text>{{match.pick.backup}}</text></view>
    <view class="lean-row"><text>总进球</text><text>{{match.pick.total}}</text></view>
    <view class="lean-row"><text>市场顺序</text><text>{{match.analysis.order}}</text></view>
    <view class="risk">
      <text>风险点：{{match.analysis.risk}}</text>
    </view>
  </view>

  <view class="sources">
    <text>Sources：FIFA World Cup 26 match schedule；公开赛程、球队资料与实时比分接口；赛前市场如未实时开放则不虚构赔率。</text>
  </view>
</view>
