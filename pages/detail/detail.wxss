.detail-page {
  padding-bottom: 44rpx;
}

.detail-hero {
  padding: 22rpx 20rpx 18rpx;
  border-radius: 22rpx;
  background: #0d0d0d;
  border: 2rpx solid rgba(214, 170, 76, 0.28);
}

.meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 21rpx;
  font-weight: 800;
}

.altitude {
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  color: #050505;
  font-size: 18rpx;
  font-weight: 1000;
}

.altitude-low {
  background: #53e26f;
}

.altitude-mid {
  background: #ffd759;
}

.altitude-high {
  background: #ff9d3d;
}

.altitude-extreme {
  background: #ff4056;
  color: #fff;
}

.altitude-unknown {
  background: rgba(255, 255, 255, 0.24);
  color: #fff;
}

.scoreline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  gap: 12rpx;
}

.side {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.big-flag {
  display: block;
  width: 76rpx;
  height: 96rpx;
  margin: 0 auto;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.18);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.24);
}

.side-title-line {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 6rpx;
  min-width: 0;
  margin-top: 6rpx;
}

.side-cn {
  display: inline;
  font-size: 25rpx;
  font-weight: 1000;
  white-space: nowrap;
}

.side-en {
  display: inline;
  color: rgba(255, 255, 255, 0.68);
  font-size: 17rpx;
  font-weight: 800;
  white-space: nowrap;
}

.side-profile {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 18rpx;
  font-weight: 900;
}

.score-core {
  flex: none;
  width: 174rpx;
  min-height: 136rpx;
  padding: 13rpx 8rpx;
  border-radius: 18rpx;
  color: #111;
  background: #fff;
  text-align: center;
}

.score-core-live {
  background: #fff4d1;
}

.score-core-finished {
  background: #d8ffe3;
}

.score-eyebrow {
  display: block;
  color: #111;
  font-size: 18rpx;
  line-height: 1.1;
  font-weight: 1000;
}

.score {
  display: block;
  margin-top: 6rpx;
  color: #b3832c;
  font-size: 44rpx;
  font-weight: 1000;
  line-height: 1;
}

.score-core-finished .score {
  color: #079342;
}

.score-predict {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.15;
  font-weight: 900;
}

.venue-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
  color: #d6aa4c;
  font-size: 21rpx;
  font-weight: 900;
}

.conclusion,
.analysis-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #141414;
}

.block-title {
  display: block;
  margin-bottom: 10rpx;
  color: #d6aa4c;
  font-size: 25rpx;
  font-weight: 1000;
}

.block-title.dark {
  color: #111;
}

.conclusion-text,
.body-line {
  display: block;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  line-height: 1.48;
}

.body-line + .body-line {
  margin-top: 8rpx;
}

.market-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
}

.market-card {
  min-height: 104rpx;
  padding: 14rpx 12rpx;
  border-radius: 16rpx;
  background: #141414;
}

.market-label {
  display: block;
  color: #d6aa4c;
  font-size: 18rpx;
  font-weight: 900;
}

.market-value {
  display: block;
  margin-top: 8rpx;
  color: #fff;
  font-size: 21rpx;
  line-height: 1.28;
  font-weight: 800;
}

.final-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  color: #111;
  background: #d6aa4c;
}

.lean-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 9rpx 0;
  border-top: 2rpx solid rgba(0, 0, 0, 0.12);
  font-size: 23rpx;
  font-weight: 900;
}

.lean-row text:last-child {
  flex: 1;
  text-align: right;
}

.risk {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.1);
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 800;
}

.reward {
  margin-top: 16rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  text-align: center;
}

.reward-title {
  display: block;
  font-size: 28rpx;
  font-weight: 1000;
}

.reward-copy {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
  line-height: 1.42;
}

.reward-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 260rpx;
  height: 70rpx;
  margin: 16rpx auto 0;
  border-radius: 999rpx;
  color: #050505;
  background: #d6aa4c;
  font-size: 25rpx;
  font-weight: 1000;
}

.sources {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 19rpx;
  line-height: 1.42;
}
